{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DopplerCorrectionLog",
  "description": "Operational processing provenance records for Doppler correction events.",
  "type": "object",
  "required": ["schema_version", "entries"],
  "properties": {
    "schema_version": {"type": "string"},
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "entry_id", "candidate_id", "track",
          "correction_kind", "status", "applied_by", "applied_at"
        ],
        "properties": {
          "entry_id": {"type": "string"},
          "candidate_id": {"type": "string"},
          "track": {"type": "string"},
          "correction_kind": {
            "type": "string",
            "enum": [
              "barycentric", "topocentric", "heliocentric",
              "observatory_frame", "rest_frame"
            ]
          },
          "status": {
            "type": "string",
            "enum": ["applied", "failed", "not_applicable", "flagged"]
          },
          "applied_by": {"type": "string"},
          "applied_at": {"type": "string"},
          "correction_hz": {"type": ["number", "null"]},
          "reference_frame": {"type": ["string", "null"]},
          "notes": {"type": ["string", "null"]}
        }
      }
    }
  }
}
