{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Candidate Deduplication Log",
  "type": "object",
  "required": ["schema_version", "candidate_deduplication_entries"],
  "properties": {
    "schema_version": { "type": "string", "const": "candidate_deduplication_log_v1" },
    "candidate_deduplication_entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "dedup_id", "candidate_id", "match_kind", "status",
          "compared_to_id", "compared_by", "compared_utc"
        ],
        "properties": {
          "dedup_id": { "type": "string" },
          "candidate_id": { "type": "string" },
          "match_kind": {
            "type": "string",
            "enum": ["cross_candidate", "known_object", "prior_epoch", "catalog_match"]
          },
          "status": {
            "type": "string",
            "enum": ["pending", "confirmed_duplicate", "confirmed_distinct", "inconclusive"]
          },
          "compared_to_id": { "type": "string" },
          "compared_by": { "type": "string" },
          "compared_utc": { "type": "string" },
          "match_score": { "type": ["number", "null"] },
          "resolved_utc": { "type": ["string", "null"] },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
