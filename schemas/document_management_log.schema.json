{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DocumentManagementLog",
  "description": "Operational provenance records for document lifecycle events.",
  "type": "object",
  "required": ["entries"],
  "properties": {
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["entry_id", "document_kind", "status", "document_id", "description"],
        "properties": {
          "entry_id": {"type": "string"},
          "document_kind": {
            "type": "string",
            "enum": ["approval", "archival", "creation", "review", "revision"]
          },
          "status": {
            "type": "string",
            "enum": ["active", "archived", "draft", "superseded"]
          },
          "document_id": {"type": "string"},
          "description": {"type": "string"},
          "notes": {"type": "string"}
        }
      }
    }
  }
}
