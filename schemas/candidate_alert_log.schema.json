{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CandidateAlertLog",
  "description": "Operational alert log for threshold crossings and status changes. Alerts are provenance records only.",
  "type": "object",
  "required": ["candidate_alert_entries"],
  "properties": {
    "candidate_alert_entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "alert_id",
          "candidate_id",
          "alert_kind",
          "severity",
          "message",
          "resolved",
          "alert_utc"
        ],
        "properties": {
          "alert_id": {"type": "string"},
          "candidate_id": {"type": "string"},
          "alert_kind": {
            "type": "string",
            "enum": [
              "score_threshold_crossed",
              "pathway_changed",
              "flag_raised",
              "rescore_triggered",
              "provenance_inconsistency",
              "deadline_approaching",
              "operator_action_required"
            ]
          },
          "severity": {
            "type": "string",
            "enum": ["info", "warning", "critical"]
          },
          "message": {"type": "string"},
          "resolved": {"type": "boolean"},
          "alert_utc": {"type": "string"},
          "resolved_utc": {"type": ["string", "null"]},
          "notes": {"type": "string"}
        }
      }
    }
  }
}
