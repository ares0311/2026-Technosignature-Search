{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FrequencyChannelLog",
  "description": "Operational processing provenance records for frequency channel configuration.",
  "type": "object",
  "required": ["frequency_channel_entries"],
  "properties": {
    "frequency_channel_entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["entry_id","candidate_id","channel_kind","status","frequency_mhz","recorded_by","recorded_at","track"],
        "properties": {
          "entry_id": {"type": "string"},
          "candidate_id": {"type": "string"},
          "channel_kind": {"type": "string", "enum": ["primary","backup","rfi_free","reserved","calibration"]},
          "status": {"type": "string", "enum": ["active","flagged","reserved","disabled"]},
          "frequency_mhz": {"type": "number"},
          "bandwidth_mhz": {"type": ["number","null"]},
          "recorded_by": {"type": "string"},
          "recorded_at": {"type": "string"},
          "track": {"type": "string"},
          "notes": {"type": ["string","null"]}
        }
      }
    }
  }
}
