{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TrainingLog",
  "description": "Operational provenance records for personnel training and certification events.",
  "type": "object",
  "required": ["entries"],
  "additionalProperties": false,
  "properties": {
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["entry_id", "training_kind", "status", "personnel_id", "training_topic"],
        "additionalProperties": false,
        "properties": {
          "entry_id": {"type": "string"},
          "training_kind": {
            "type": "string",
            "enum": ["certification", "compliance_training", "onboarding", "skills_development", "vendor_training"]
          },
          "status": {
            "type": "string",
            "enum": ["completed", "expired", "in_progress", "scheduled"]
          },
          "personnel_id": {"type": "string"},
          "training_topic": {"type": "string"},
          "notes": {"type": "string"}
        }
      }
    }
  }
}
