{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DataArchivalLog",
  "description": "Operational provenance records for observation data archival events.",
  "type": "object",
  "required": ["schema_version", "entries"],
  "properties": {
    "schema_version": {"type": "string"},
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "entry_id", "candidate_id", "track",
          "archival_kind", "status", "archived_by", "archived_at"
        ],
        "properties": {
          "entry_id": {"type": "string"},
          "candidate_id": {"type": "string"},
          "track": {"type": "string"},
          "archival_kind": {
            "type": "string",
            "enum": [
              "raw_data", "processed_data", "candidate_packet",
              "pipeline_artifact", "calibration_data"
            ]
          },
          "status": {
            "type": "string",
            "enum": ["archived", "pending", "failed", "deleted"]
          },
          "archived_by": {"type": "string"},
          "archived_at": {"type": "string"},
          "artifact_path": {"type": ["string", "null"]},
          "size_bytes": {"type": ["integer", "null"]},
          "notes": {"type": ["string", "null"]}
        }
      }
    }
  }
}
