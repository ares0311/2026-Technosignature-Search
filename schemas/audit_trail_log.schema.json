{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "audit_trail_log.schema.json",
  "title": "Audit Trail Log",
  "description": "Operational provenance records for audit trail events.",
  "type": "object",
  "required": ["schema_version", "disclaimer", "entries"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "audit_trail_log_v1"
    },
    "disclaimer": {
      "type": "string"
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/AuditTrailEntry"
      }
    }
  },
  "$defs": {
    "AuditTrailEntry": {
      "type": "object",
      "required": [
        "entry_id",
        "audit_kind",
        "status",
        "actor_id",
        "resource_id",
        "timestamp_utc"
      ],
      "properties": {
        "entry_id": { "type": "string" },
        "audit_kind": {
          "type": "string",
          "enum": [
            "compliance_check",
            "config_change",
            "data_access",
            "system_event",
            "user_action"
          ]
        },
        "status": {
          "type": "string",
          "enum": ["archived", "flagged", "recorded", "reviewed"]
        },
        "actor_id": { "type": "string" },
        "resource_id": { "type": "string" },
        "timestamp_utc": { "type": "string" },
        "notes": {
          "oneOf": [{ "type": "string" }, { "type": "null" }]
        }
      },
      "additionalProperties": false
    }
  }
}
