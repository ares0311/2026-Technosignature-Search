{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RfiMitigationLog",
  "description": "Operational processing provenance records for RFI mitigation actions.",
  "type": "object",
  "required": ["rfi_mitigation_entries"],
  "properties": {
    "rfi_mitigation_entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["entry_id","candidate_id","mitigation_kind","action","mitigated_by","mitigated_at","track"],
        "properties": {
          "entry_id": {"type": "string"},
          "candidate_id": {"type": "string"},
          "mitigation_kind": {"type": "string", "enum": ["known_rfi_source","statistical_outlier","satellite_track","terrestrial_interference","other"]},
          "action": {"type": "string", "enum": ["flagged","excised","masked","passed","deferred"]},
          "mitigated_by": {"type": "string"},
          "mitigated_at": {"type": "string"},
          "track": {"type": "string"},
          "frequency_mhz": {"type": ["number","null"]},
          "notes": {"type": "string"}
        }
      }
    }
  }
}
