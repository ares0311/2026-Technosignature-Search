{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PatchManagementLog",
  "description": "Operational provenance records for patch management events.",
  "type": "object",
  "required": ["schema_version", "entries"],
  "properties": {
    "schema_version": {"type": "string"},
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["entry_id", "patch_kind", "status", "actor_id", "resource_id", "timestamp_utc"],
        "properties": {
          "entry_id": {"type": "string"},
          "patch_kind": {"type": "string", "enum": ["critical_patch", "feature_update", "hotfix", "rollback", "security_patch"]},
          "status": {"type": "string", "enum": ["applied", "failed", "pending", "skipped"]},
          "actor_id": {"type": "string"},
          "resource_id": {"type": "string"},
          "timestamp_utc": {"type": "string"},
          "notes": {"type": ["string", "null"]}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
