{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SQLite Operational Log Adapter Execution Preview",
  "type": "object",
  "required": ["schema_version", "expected_preview"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "sqlite_operational_log_adapter_execution_preview_v1"
    },
    "expected_preview": {
      "type": "object",
      "required": [
        "expected_insert_count",
        "expected_phase_count",
        "expected_operation_count",
        "begin_statement",
        "commit_statement",
        "require_insert_preview_ok",
        "require_transaction_markers",
        "require_phase_tables",
        "require_phase_inserts",
        "execution_allowed",
        "mutation_allowed"
      ],
      "properties": {
        "expected_insert_count": {
          "type": "integer",
          "minimum": 0
        },
        "expected_phase_count": {
          "type": "integer",
          "minimum": 0
        },
        "expected_operation_count": {
          "type": "integer",
          "minimum": 0
        },
        "begin_statement": {
          "type": "string",
          "minLength": 1
        },
        "commit_statement": {
          "type": "string",
          "minLength": 1
        },
        "require_insert_preview_ok": {
          "type": "boolean"
        },
        "require_transaction_markers": {
          "type": "boolean"
        },
        "require_phase_tables": {
          "type": "boolean"
        },
        "require_phase_inserts": {
          "type": "boolean"
        },
        "execution_allowed": {
          "type": "boolean",
          "const": false
        },
        "mutation_allowed": {
          "type": "boolean",
          "const": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
