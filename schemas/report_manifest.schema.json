{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ares0311/Technosignature-Search/schemas/report_manifest.schema.json",
  "title": "Technosignature Search Report Manifest",
  "type": "object",
  "required": [
    "candidate_id",
    "track",
    "recommended_pathway",
    "schema_version",
    "markdown_path",
    "json_path",
    "config_version",
    "code_commit",
    "generated_at_utc",
    "provenance_summary"
  ],
  "properties": {
    "candidate_id": { "type": "string", "minLength": 1 },
    "track": { "enum": ["radio", "infrared", "anomaly"] },
    "recommended_pathway": { "type": "string", "minLength": 1 },
    "schema_version": { "type": "string", "minLength": 1 },
    "markdown_path": { "type": "string", "minLength": 1 },
    "json_path": { "type": "string", "minLength": 1 },
    "config_version": { "type": "string", "minLength": 1 },
    "code_commit": { "type": ["string", "null"] },
    "generated_at_utc": { "type": "string", "minLength": 1 },
    "provenance_summary": {
      "type": "object",
      "required": [
        "schema_version",
        "config_version",
        "generated_at_utc",
        "code_commit",
        "query_parameters",
        "source_ids"
      ],
      "properties": {
        "schema_version": { "type": "string", "minLength": 1 },
        "config_version": { "type": "string", "minLength": 1 },
        "generated_at_utc": { "type": "string", "minLength": 1 },
        "code_commit": { "type": ["string", "null"] },
        "input_path": { "type": ["string", "null"] },
        "provider_name": { "type": ["string", "null"] },
        "query_parameters": { "type": "object" },
        "source_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "source_dataset": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
