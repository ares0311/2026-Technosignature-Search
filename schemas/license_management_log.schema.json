{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LicenseManagementLog",
  "description": "Operational provenance records for software license lifecycle events.",
  "type": "object",
  "required": ["schema_version", "disclaimer", "entries"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "license_management_log_v1"
    },
    "disclaimer": {
      "type": "string"
    },
    "entries": {
      "type": "array",
      "items": { "$ref": "#/$defs/LicenseManagementEntry" }
    }
  },
  "$defs": {
    "LicenseManagementEntry": {
      "type": "object",
      "required": ["entry_id", "license_kind", "status", "actor_id", "resource_id", "timestamp_utc"],
      "properties": {
        "entry_id": { "type": "string" },
        "license_kind": {
          "type": "string",
          "enum": ["activation", "deactivation", "expiry_warning", "renewal", "transfer"]
        },
        "status": {
          "type": "string",
          "enum": ["active", "expired", "failed", "renewed"]
        },
        "actor_id": { "type": "string" },
        "resource_id": { "type": "string" },
        "timestamp_utc": { "type": "string" },
        "notes": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
