{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AuditFindingLog",
  "description": "Operational provenance records for formal audit finding events.",
  "type": "object",
  "required": ["entries"],
  "additionalProperties": false,
  "properties": {
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["entry_id", "finding_kind", "status", "audit_ref", "description"],
        "additionalProperties": false,
        "properties": {
          "entry_id": {"type": "string"},
          "finding_kind": {
            "type": "string",
            "enum": ["compliance_gap", "configuration_issue", "documentation_gap", "process_gap", "security_finding"]
          },
          "status": {
            "type": "string",
            "enum": ["accepted", "closed", "open", "remediated"]
          },
          "audit_ref": {"type": "string"},
          "description": {"type": "string"},
          "notes": {"type": "string"}
        }
      }
    }
  }
}
