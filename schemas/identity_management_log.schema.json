{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IdentityManagementLog",
  "description": "Operational provenance records for identity management events.",
  "type": "object",
  "required": ["schema_version", "entries"],
  "properties": {
    "schema_version": {"type": "string"},
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["entry_id", "identity_kind", "status", "actor_id", "resource_id", "timestamp_utc"],
        "properties": {
          "entry_id": {"type": "string"},
          "identity_kind": {"type": "string", "enum": ["account_creation", "account_deletion", "password_reset", "privilege_change", "role_assignment"]},
          "status": {"type": "string", "enum": ["active", "expired", "pending", "revoked"]},
          "actor_id": {"type": "string"},
          "resource_id": {"type": "string"},
          "timestamp_utc": {"type": "string"},
          "notes": {"type": ["string", "null"]}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
