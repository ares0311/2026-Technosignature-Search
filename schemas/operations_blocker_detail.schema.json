{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OperationsBlockerDetail",
  "description": "Fixture-backed local evidence detail for operations action-plan blockers. This artifact does not clear blockers, authorize live data access, or authorize external submission.",
  "type": "object",
  "required": [
    "schema_version",
    "disclaimer",
    "action_count",
    "detail_count",
    "total_evidence_record_count",
    "categories_with_details",
    "local_only",
    "network_access_allowed_count",
    "external_submission_approved_count",
    "all_external_authorization_disabled",
    "readiness_recommendation",
    "readiness_real_data_blocker_count",
    "sqlite_visibility_context",
    "sqlite_context_is_resolved",
    "details"
  ],
  "properties": {
    "schema_version": {"const": "operations_blocker_detail_v1"},
    "disclaimer": {"type": "string"},
    "action_count": {"type": "integer", "minimum": 0},
    "detail_count": {"type": "integer", "minimum": 0},
    "total_evidence_record_count": {"type": "integer", "minimum": 0},
    "categories_with_details": {
      "type": "array",
      "items": {"type": "string"}
    },
    "local_only": {"type": "boolean", "const": true},
    "network_access_allowed_count": {"type": "integer", "minimum": 0},
    "external_submission_approved_count": {"type": "integer", "minimum": 0},
    "all_external_authorization_disabled": {"type": "boolean"},
    "readiness_recommendation": {"type": "string"},
    "readiness_real_data_blocker_count": {"type": "integer", "minimum": 0},
    "sqlite_visibility_context": {
      "type": "object",
      "required": [
        "category",
        "present",
        "integrity_ok",
        "weekly_digest_ok",
        "network_access_allowed_count",
        "external_submission_approved_count",
        "note"
      ],
      "properties": {
        "category": {"const": "sqlite_logs"},
        "present": {"type": "boolean"},
        "integrity_ok": {"type": "boolean"},
        "weekly_digest_ok": {"type": "boolean"},
        "network_access_allowed_count": {"type": "integer", "minimum": 0},
        "external_submission_approved_count": {"type": "integer", "minimum": 0},
        "log_path": {"type": ["string", "null"]},
        "note": {"type": "string"}
      },
      "additionalProperties": false
    },
    "sqlite_context_is_resolved": {"type": "boolean"},
    "details": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "action_id",
          "category",
          "priority",
          "status",
          "title",
          "evidence_field",
          "blocker_count",
          "required_action",
          "source_summary",
          "evidence_records",
          "record_count"
        ],
        "properties": {
          "action_id": {"type": "string"},
          "category": {"type": "string"},
          "priority": {"type": "string"},
          "status": {"type": "string"},
          "title": {"type": "string"},
          "evidence_field": {"type": "string"},
          "blocker_count": {"type": "integer", "minimum": 0},
          "required_action": {"type": "string"},
          "source_summary": {"type": "object"},
          "evidence_records": {"type": "object"},
          "record_count": {"type": "integer", "minimum": 0}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
