{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Operations Blocker Progress Consistency Expectations",
  "description": "Expected local blocker-progress chain counts, residual blockers, categories, and authorization state for workflow visibility gates.",
  "type": "object",
  "required": ["schema_version", "expected_progress"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "operations_blocker_progress_consistency_v1"
    },
    "expected_progress": {
      "type": "object",
      "required": [
        "detail_count",
        "review_record_count",
        "followup_action_count",
        "progress_record_count",
        "unresolved_progress_count",
        "verified_local_count",
        "progress_review_record_count",
        "next_action_record_count",
        "execution_record_count",
        "execution_review_record_count",
        "execution_followup_record_count",
        "operator_followup_required_count",
        "local_note_followup_ready_count",
        "blocked_pending_real_data_count",
        "residual_blocker_total",
        "verified_progress_action_ids",
        "categories_covered",
        "require_coverage_complete",
        "require_priority_sequence_ok",
        "require_zero_mismatches",
        "require_zero_live_data_authorization",
        "require_zero_external_authorization"
      ],
      "properties": {
        "detail_count": {"type": "integer", "minimum": 0},
        "review_record_count": {"type": "integer", "minimum": 0},
        "followup_action_count": {"type": "integer", "minimum": 0},
        "progress_record_count": {"type": "integer", "minimum": 0},
        "unresolved_progress_count": {"type": "integer", "minimum": 0},
        "verified_local_count": {"type": "integer", "minimum": 0},
        "progress_review_record_count": {"type": "integer", "minimum": 0},
        "next_action_record_count": {"type": "integer", "minimum": 0},
        "execution_record_count": {"type": "integer", "minimum": 0},
        "execution_review_record_count": {"type": "integer", "minimum": 0},
        "execution_followup_record_count": {"type": "integer", "minimum": 0},
        "operator_followup_required_count": {"type": "integer", "minimum": 0},
        "local_note_followup_ready_count": {"type": "integer", "minimum": 0},
        "blocked_pending_real_data_count": {"type": "integer", "minimum": 0},
        "residual_blocker_total": {"type": "integer", "minimum": 0},
        "verified_progress_action_ids": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "categories_covered": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "require_coverage_complete": {"type": "boolean"},
        "require_priority_sequence_ok": {"type": "boolean"},
        "require_zero_mismatches": {"type": "boolean"},
        "require_zero_live_data_authorization": {"type": "boolean"},
        "require_zero_external_authorization": {"type": "boolean"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
