{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/techno-search/validation_readiness.schema.json",
  "title": "Technosignature Search validation readiness records",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "description",
    "disclaimer",
    "records"
  ],
  "properties": {
    "schema_version": {
      "const": "validation_readiness_v1"
    },
    "description": {
      "type": "string"
    },
    "disclaimer": {
      "type": "string"
    },
    "records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "readiness_id",
          "dataset_id",
          "track",
          "dataset_kind",
          "readiness_status",
          "current_case_count",
          "minimum_case_count",
          "evidence_requirements",
          "satisfied_evidence",
          "blocking_issues",
          "requires_external_review",
          "promotion_target"
        ],
        "properties": {
          "readiness_id": {
            "type": "string"
          },
          "dataset_id": {
            "type": "string"
          },
          "track": {
            "enum": [
              "radio",
              "infrared",
              "anomaly"
            ]
          },
          "dataset_kind": {
            "type": "string"
          },
          "readiness_status": {
            "enum": [
              "ready",
              "blocked",
              "not_yet_admissible"
            ]
          },
          "current_case_count": {
            "type": "integer",
            "minimum": 0
          },
          "minimum_case_count": {
            "type": "integer",
            "minimum": 1
          },
          "evidence_requirements": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "satisfied_evidence": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "blocking_issues": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "requires_external_review": {
            "type": "boolean"
          },
          "promotion_target": {
            "type": "string"
          }
        }
      }
    }
  }
}
