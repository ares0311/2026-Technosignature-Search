{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AlertResolutionLog",
  "description": "Provenance records tracking how open candidate alerts are formally closed. Alert resolution does not authorize external submission or constitute a detection claim.",
  "type": "object",
  "required": ["alert_resolution_entries"],
  "properties": {
    "alert_resolution_entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "resolution_id",
          "candidate_id",
          "linked_alert_ids",
          "status",
          "resolution_kind",
          "resolving_operator",
          "resolution_utc"
        ],
        "properties": {
          "resolution_id": {"type": "string"},
          "candidate_id": {"type": "string"},
          "linked_alert_ids": {
            "type": "array",
            "items": {"type": "string"}
          },
          "status": {
            "type": "string",
            "enum": [
              "resolved_false_positive",
              "resolved_follow_up",
              "resolved_archived",
              "resolved_operator_closed",
              "open"
            ]
          },
          "resolution_kind": {
            "type": "string",
            "enum": [
              "operator_review",
              "automated_consistency_check",
              "deadline_expiry",
              "pathway_confirmed",
              "watchlist_action"
            ]
          },
          "resolving_operator": {"type": "string"},
          "resolution_utc": {"type": "string"},
          "notes": {"type": "string"}
        }
      }
    }
  }
}
