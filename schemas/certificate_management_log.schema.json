{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CertificateManagementLog",
  "description": "Operational provenance records for certificate management events.",
  "type": "object",
  "required": ["schema_version", "entries"],
  "properties": {
    "schema_version": {"type": "string"},
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["entry_id", "certificate_kind", "status", "actor_id", "resource_id", "timestamp_utc"],
        "properties": {
          "entry_id": {"type": "string"},
          "certificate_kind": {"type": "string", "enum": ["ca_certificate", "client_certificate", "code_signing", "server_certificate", "tls_renewal"]},
          "status": {"type": "string", "enum": ["expired", "issued", "renewed", "revoked"]},
          "actor_id": {"type": "string"},
          "resource_id": {"type": "string"},
          "timestamp_utc": {"type": "string"},
          "notes": {"type": ["string", "null"]}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
