{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/techno-search/background_reviewed_log.schema.json",
  "title": "Technosignature Search reviewed background-search log",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "description",
    "disclaimer",
    "reviewed_entries"
  ],
  "properties": {
    "schema_version": {
      "const": "background_reviewed_log_v1"
    },
    "description": {
      "type": "string"
    },
    "disclaimer": {
      "type": "string"
    },
    "reviewed_entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "review_id",
          "run_id",
          "target_id",
          "track",
          "outcome_status",
          "reviewed_at_utc",
          "reason_codes",
          "negative_evidence",
          "blocking_issues",
          "recommended_next_action",
          "network_access_allowed"
        ],
        "properties": {
          "review_id": {
            "type": "string"
          },
          "run_id": {
            "type": "string"
          },
          "target_id": {
            "type": "string"
          },
          "track": {
            "enum": [
              "radio",
              "infrared",
              "anomaly"
            ]
          },
          "outcome_status": {
            "const": "reviewed_no_follow_up"
          },
          "reviewed_at_utc": {
            "type": "string"
          },
          "reason_codes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "negative_evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "blocking_issues": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "recommended_next_action": {
            "enum": [
              "retain_in_reviewed_log",
              "reschedule_after_new_data",
              "no_action_required"
            ]
          },
          "network_access_allowed": {
            "const": false
          }
        }
      }
    }
  }
}
