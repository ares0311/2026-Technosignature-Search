{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/operations_blocker_progress_execution_followup.schema.json",
  "title": "Operations Blocker Progress Execution Follow-Up Records",
  "type": "object",
  "required": [
    "schema_version",
    "disclaimer",
    "operations_blocker_progress_execution_followup_records"
  ],
  "properties": {
    "schema_version": {
      "const": "operations_blocker_progress_execution_followup_v1"
    },
    "disclaimer": {
      "type": "string",
      "minLength": 1
    },
    "operations_blocker_progress_execution_followup_records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "followup_id",
          "review_id",
          "execution_id",
          "next_action_id",
          "action_id",
          "category",
          "review_status",
          "followup_status",
          "priority_rank",
          "operator_id",
          "planned_utc",
          "followup_note",
          "residual_blocker_count",
          "live_data_authorized",
          "external_submission_authorized"
        ],
        "properties": {
          "followup_id": {
            "type": "string",
            "minLength": 1
          },
          "review_id": {
            "type": "string",
            "minLength": 1
          },
          "execution_id": {
            "type": "string",
            "minLength": 1
          },
          "next_action_id": {
            "type": "string",
            "minLength": 1
          },
          "action_id": {
            "type": "string",
            "minLength": 1
          },
          "category": {
            "type": "string",
            "enum": [
              "alerts",
              "capacity",
              "curated_intake",
              "external_submission",
              "network_access",
              "pipeline_health",
              "quality_control",
              "review_deadlines",
              "route_coverage",
              "sqlite_logs",
              "submission_provenance",
              "validation_readiness"
            ]
          },
          "review_status": {
            "type": "string",
            "enum": [
              "awaiting_operator_reviewed",
              "blocked_pending_real_data_reviewed",
              "execution_note_reviewed",
              "no_execution_required_reviewed",
              "policy_review_pending"
            ]
          },
          "followup_status": {
            "type": "string",
            "enum": [
              "blocked_pending_real_data",
              "local_note_followup_ready",
              "no_followup_required",
              "operator_followup_required",
              "policy_review_pending"
            ]
          },
          "priority_rank": {
            "type": "integer",
            "minimum": 1
          },
          "operator_id": {
            "type": "string",
            "minLength": 1
          },
          "planned_utc": {
            "type": "string",
            "format": "date-time"
          },
          "followup_note": {
            "type": "string",
            "minLength": 1
          },
          "residual_blocker_count": {
            "type": "integer",
            "minimum": 0
          },
          "live_data_authorized": {
            "type": "boolean"
          },
          "external_submission_authorized": {
            "type": "boolean"
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
