{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DataTransferLog",
  "description": "Operational provenance records for data transfer and synchronization events.",
  "type": "object",
  "required": ["schema_version", "disclaimer", "entries"],
  "properties": {
    "schema_version": { "type": "string", "const": "data_transfer_log_v1" },
    "disclaimer": { "type": "string" },
    "entries": { "type": "array", "items": { "$ref": "#/$defs/DataTransferEntry" } }
  },
  "$defs": {
    "DataTransferEntry": {
      "type": "object",
      "required": ["entry_id", "transfer_kind", "status", "actor_id", "source_id", "destination_id", "timestamp_utc"],
      "properties": {
        "entry_id": { "type": "string" },
        "transfer_kind": {
          "type": "string",
          "enum": ["bulk_export", "emergency_transfer", "inbound_transfer", "internal_sync", "outbound_transfer"]
        },
        "status": { "type": "string", "enum": ["cancelled", "completed", "failed", "in_progress"] },
        "actor_id": { "type": "string" },
        "source_id": { "type": "string" },
        "destination_id": { "type": "string" },
        "timestamp_utc": { "type": "string" },
        "notes": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
