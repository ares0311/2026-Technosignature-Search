{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AssetManagementLog",
  "description": "Operational provenance records for asset management events.",
  "type": "object",
  "required": ["schema_version", "entries"],
  "properties": {
    "schema_version": {"type": "string"},
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["entry_id", "asset_kind", "status", "actor_id", "resource_id", "timestamp_utc"],
        "properties": {
          "entry_id": {"type": "string"},
          "asset_kind": {"type": "string", "enum": ["asset_acquisition", "asset_audit", "asset_decommission", "asset_maintenance", "asset_transfer"]},
          "status": {"type": "string", "enum": ["active", "decommissioned", "pending", "under_maintenance"]},
          "actor_id": {"type": "string"},
          "resource_id": {"type": "string"},
          "timestamp_utc": {"type": "string"},
          "notes": {"type": ["string", "null"]}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
