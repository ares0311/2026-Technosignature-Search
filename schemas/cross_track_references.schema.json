{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/cross_track_references.schema.json",
  "title": "Cross-Track Candidate References",
  "description": "Operational cross-reference metadata linking candidate IDs that share a target across tracks. Cross-references are not detections, discoveries, external validation, or score adjustments.",
  "type": "object",
  "required": ["schema_version", "disclaimer", "references"],
  "properties": {
    "schema_version": {"const": "cross_track_references_v1"},
    "disclaimer": {"type": "string"},
    "description": {"type": "string"},
    "references": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "reference_id",
          "target_id",
          "contributing_tracks",
          "candidate_packet_ids",
          "recommended_pathway",
          "blocking_issues",
          "negative_evidence",
          "cross_reference_kind"
        ],
        "properties": {
          "reference_id": {"type": "string"},
          "target_id": {"type": "string"},
          "contributing_tracks": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "enum": ["radio", "infrared", "anomaly"]}
          },
          "candidate_packet_ids": {
            "type": "array",
            "items": {"type": "string"}
          },
          "recommended_pathway": {"type": "string"},
          "blocking_issues": {
            "type": "array",
            "items": {"type": "string"}
          },
          "negative_evidence": {
            "type": "array",
            "items": {"type": "string"}
          },
          "cross_reference_kind": {
            "type": "string",
            "enum": [
              "operational_cross_reference",
              "conflicting_evidence",
              "single_track_only",
              "known_object_cross_match"
            ]
          },
          "notes": {"type": "string"}
        }
      }
    }
  }
}
