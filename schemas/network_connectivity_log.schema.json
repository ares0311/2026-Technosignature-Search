{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "network_connectivity_log.schema.json",
  "title": "Network Connectivity Log",
  "description": "Operational provenance records for observatory network connectivity events.",
  "type": "object",
  "required": ["schema_version", "disclaimer", "entries"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "network_connectivity_log_v1"
    },
    "disclaimer": {
      "type": "string"
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/NetworkConnectivityEntry"
      }
    }
  },
  "$defs": {
    "NetworkConnectivityEntry": {
      "type": "object",
      "required": [
        "entry_id",
        "network_kind",
        "status",
        "recorded_by",
        "timestamp_utc"
      ],
      "properties": {
        "entry_id": { "type": "string" },
        "network_kind": {
          "type": "string",
          "enum": [
            "link_up",
            "link_down",
            "latency_spike",
            "packet_loss",
            "vpn_event"
          ]
        },
        "status": {
          "type": "string",
          "enum": ["connected", "degraded", "disconnected", "restored"]
        },
        "recorded_by": { "type": "string" },
        "timestamp_utc": { "type": "string" },
        "interface_id": {
          "oneOf": [{ "type": "string" }, { "type": "null" }]
        },
        "latency_ms": {
          "oneOf": [{ "type": "number" }, { "type": "null" }]
        },
        "notes": {
          "oneOf": [{ "type": "string" }, { "type": "null" }]
        }
      },
      "additionalProperties": false
    }
  }
}
