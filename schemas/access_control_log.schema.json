{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AccessControlLog",
  "description": "Operational provenance records for access control events.",
  "type": "object",
  "required": ["schema_version", "entries"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "access_control_log_v1"
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["entry_id", "access_kind", "status", "actor_id", "resource_id", "timestamp_utc"],
        "properties": {
          "entry_id": {"type": "string"},
          "access_kind": {
            "type": "string",
            "enum": ["access_grant", "access_revocation", "authentication_attempt", "authorization_check", "permission_change"]
          },
          "status": {
            "type": "string",
            "enum": ["allowed", "blocked", "expired", "pending"]
          },
          "actor_id": {"type": "string"},
          "resource_id": {"type": "string"},
          "timestamp_utc": {"type": "string"},
          "notes": {"type": ["string", "null"]}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
