{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ResourceAllocationLog",
  "description": "Operational provenance records for compute and facility resource allocation events.",
  "type": "object",
  "required": ["schema_version", "disclaimer", "entries"],
  "properties": {
    "schema_version": { "type": "string", "const": "resource_allocation_log_v1" },
    "disclaimer": { "type": "string" },
    "entries": { "type": "array", "items": { "$ref": "#/$defs/ResourceAllocationEntry" } }
  },
  "$defs": {
    "ResourceAllocationEntry": {
      "type": "object",
      "required": ["entry_id", "allocation_kind", "status", "actor_id", "resource_id", "timestamp_utc"],
      "properties": {
        "entry_id": { "type": "string" },
        "allocation_kind": {
          "type": "string",
          "enum": ["compute_allocation", "memory_allocation", "network_allocation", "personnel_allocation", "storage_allocation"]
        },
        "status": { "type": "string", "enum": ["allocated", "deallocated", "exhausted", "pending"] },
        "actor_id": { "type": "string" },
        "resource_id": { "type": "string" },
        "timestamp_utc": { "type": "string" },
        "notes": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
