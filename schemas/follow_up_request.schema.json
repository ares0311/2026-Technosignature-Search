{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FollowUpRequest",
  "description": "Schema for follow-up request fixture files (follow_up_request_v1).",
  "type": "object",
  "required": ["schema_version", "disclaimer", "requests"],
  "properties": {
    "schema_version": { "type": "string" },
    "disclaimer": { "type": "string" },
    "requests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "request_id", "candidate_id", "track", "priority",
          "status", "requested_by", "requested_utc"
        ],
        "properties": {
          "request_id": { "type": "string" },
          "candidate_id": { "type": "string" },
          "track": { "type": "string", "enum": ["radio", "infrared", "anomaly"] },
          "priority": { "type": "string", "enum": ["low", "normal", "high", "urgent"] },
          "status": {
            "type": "string",
            "enum": ["open", "assigned", "in_progress", "completed", "cancelled", "deferred"]
          },
          "requested_by": { "type": "string" },
          "assigned_to": { "type": "string" },
          "request_reason": { "type": "string" },
          "requested_utc": { "type": "string", "format": "date-time" },
          "due_utc": { "type": "string" },
          "days_open": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
