{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BaselinePerformanceHistory",
  "description": "Append-only history of baseline eval snapshots. Each entry is a synthetic local diagnostic only.",
  "type": "object",
  "required": ["schema_version", "disclaimer", "snapshots"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "baseline_performance_history_v1"
    },
    "disclaimer": {
      "type": "string"
    },
    "snapshots": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "snapshot_date",
          "model_version",
          "total_cases",
          "pathway_accuracy",
          "false_positive_recall",
          "candidate_precision"
        ],
        "properties": {
          "snapshot_date": {"type": "string"},
          "model_version": {"type": "string"},
          "total_cases": {"type": "integer", "minimum": 0},
          "pathway_accuracy": {"type": "number", "minimum": 0.0, "maximum": 1.0},
          "false_positive_recall": {"type": "number", "minimum": 0.0, "maximum": 1.0},
          "candidate_precision": {"type": "number", "minimum": 0.0, "maximum": 1.0},
          "mean_rule_coverage": {"type": "number", "minimum": 0.0, "maximum": 1.0},
          "notes": {"type": "string"}
        }
      }
    }
  }
}
