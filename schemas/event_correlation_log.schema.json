{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EventCorrelationLog",
  "description": "Operational provenance records for cross-system event correlation runs.",
  "type": "object",
  "required": ["schema_version", "disclaimer", "entries"],
  "properties": {
    "schema_version": { "type": "string", "const": "event_correlation_log_v1" },
    "disclaimer": { "type": "string" },
    "entries": { "type": "array", "items": { "$ref": "#/$defs/EventCorrelationEntry" } }
  },
  "$defs": {
    "EventCorrelationEntry": {
      "type": "object",
      "required": ["entry_id", "correlation_kind", "status", "actor_id", "resource_id", "timestamp_utc"],
      "properties": {
        "entry_id": { "type": "string" },
        "correlation_kind": {
          "type": "string",
          "enum": ["alert_cluster", "causal_chain", "fault_event", "observation_link", "temporal_cluster"]
        },
        "status": { "type": "string", "enum": ["correlated", "inconclusive", "no_match", "pending"] },
        "actor_id": { "type": "string" },
        "resource_id": { "type": "string" },
        "timestamp_utc": { "type": "string" },
        "notes": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
