{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Project Status Consistency Expectations",
  "description": "Expected local project readiness metadata for documentation and validation drift checks.",
  "type": "object",
  "required": ["schema_version", "expected_status"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "project_status_consistency_v1"
    },
    "expected_status": {
      "type": "object",
      "required": [
        "latest_milestone_number",
        "latest_milestone_label",
        "latest_decision_number",
        "schema_count",
        "expected_rfi_real_data_authorization_total",
        "expected_curated_real_data_authorization_total",
        "project_status_completed_phrase"
      ],
      "properties": {
        "latest_milestone_number": {"type": "integer", "minimum": 1},
        "latest_milestone_label": {"type": "string", "minLength": 1},
        "latest_decision_number": {"type": "integer", "minimum": 1},
        "schema_count": {"type": "integer", "minimum": 1},
        "expected_rfi_real_data_authorization_total": {
          "type": "integer",
          "minimum": 0
        },
        "expected_curated_real_data_authorization_total": {
          "type": "integer",
          "minimum": 0
        },
        "project_status_completed_phrase": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
