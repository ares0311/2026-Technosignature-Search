{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/techno-search/consensus_export.schema.json",
  "title": "Technosignature Search human-review consensus export",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "description",
    "disclaimer",
    "exports"
  ],
  "properties": {
    "schema_version": {
      "const": "human_review_consensus_export_v1"
    },
    "description": {
      "type": "string"
    },
    "disclaimer": {
      "type": "string"
    },
    "exports": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "candidate_id",
          "track",
          "consensus_label",
          "export_path",
          "evidence_summary",
          "negative_evidence_count",
          "blocking_issue_count",
          "reviewer_decision_count"
        ],
        "properties": {
          "candidate_id": {
            "type": "string"
          },
          "track": {
            "enum": [
              "radio",
              "infrared",
              "anomaly"
            ]
          },
          "consensus_label": {
            "enum": [
              "follow_up_target",
              "insufficient_evidence",
              "known_object_annotation",
              "likely_false_positive",
              "no_consensus"
            ]
          },
          "export_path": {
            "type": "string"
          },
          "evidence_summary": {
            "type": "string"
          },
          "negative_evidence_count": {
            "type": "integer",
            "minimum": 0
          },
          "blocking_issue_count": {
            "type": "integer",
            "minimum": 0
          },
          "reviewer_decision_count": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    }
  }
}
