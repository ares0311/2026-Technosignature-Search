{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BeamConfigurationLog",
  "description": "Operational processing provenance records for radio telescope beam configuration.",
  "type": "object",
  "required": ["beam_configuration_entries"],
  "properties": {
    "beam_configuration_entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["entry_id","candidate_id","beam_kind","status","configured_by","configured_at","track"],
        "properties": {
          "entry_id": {"type": "string"},
          "candidate_id": {"type": "string"},
          "beam_kind": {"type": "string", "enum": ["primary_beam","sidelobe","calibrator_beam","off_source","synthetic_beam"]},
          "status": {"type": "string", "enum": ["configured","applied","superseded","failed"]},
          "azimuth_deg": {"type": ["number","null"]},
          "elevation_deg": {"type": ["number","null"]},
          "configured_by": {"type": "string"},
          "configured_at": {"type": "string"},
          "track": {"type": "string"},
          "notes": {"type": ["string","null"]}
        }
      }
    }
  }
}
