{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CandidateMatchLog",
  "type": "object",
  "required": ["schema_version", "candidate_match_entries"],
  "properties": {
    "schema_version": {"type": "string"},
    "candidate_match_entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["match_id", "candidate_id", "match_source", "status", "matched_by", "matched_utc"],
        "properties": {
          "match_id": {"type": "string"},
          "candidate_id": {"type": "string"},
          "match_source": {
            "type": "string",
            "enum": ["simbad", "gaia", "vizier", "irsa", "internal_catalog"]
          },
          "status": {
            "type": "string",
            "enum": ["matched", "no_match", "ambiguous", "pending"]
          },
          "matched_by": {"type": "string"},
          "matched_utc": {"type": "string"},
          "angular_separation_arcsec": {"type": ["number", "null"]},
          "matched_object_id": {"type": ["string", "null"]},
          "matched_object_type": {"type": ["string", "null"]},
          "notes": {"type": "string"}
        }
      }
    }
  }
}
