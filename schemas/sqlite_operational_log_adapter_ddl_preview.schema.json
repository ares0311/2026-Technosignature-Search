{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "sqlite_operational_log_adapter_ddl_preview.schema.json",
  "title": "SQLite Operational Log Adapter DDL Preview",
  "type": "object",
  "required": ["schema_version", "expected_preview"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "sqlite_operational_log_adapter_ddl_preview_v1"
    },
    "expected_preview": {
      "type": "object",
      "required": [
        "expected_statement_count",
        "required_clauses",
        "require_adapter_contract_ok",
        "require_required_clauses",
        "execution_allowed"
      ],
      "properties": {
        "expected_statement_count": { "type": "integer", "minimum": 1 },
        "required_clauses": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "require_adapter_contract_ok": { "type": "boolean" },
        "require_required_clauses": { "type": "boolean" },
        "execution_allowed": { "type": "boolean", "const": false }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
