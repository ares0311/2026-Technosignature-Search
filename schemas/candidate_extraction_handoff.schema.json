{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/techno-search/candidate_extraction_handoff.schema.json",
  "title": "Technosignature Search candidate extraction handoff records",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "description",
    "disclaimer",
    "handoffs"
  ],
  "properties": {
    "schema_version": {
      "const": "candidate_extraction_handoff_v1"
    },
    "description": {
      "type": "string"
    },
    "disclaimer": {
      "type": "string"
    },
    "handoffs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "handoff_id",
          "target_id",
          "track",
          "source_id",
          "extraction_status",
          "execution_mode",
          "ledger_run_id",
          "reviewed_workflow_status",
          "required_inputs",
          "available_inputs",
          "expected_candidate_packet_ids",
          "candidate_fixture_path",
          "blocking_issues",
          "negative_result_required",
          "requires_human_review",
          "network_access_allowed"
        ],
        "properties": {
          "handoff_id": {
            "type": "string"
          },
          "target_id": {
            "type": "string"
          },
          "track": {
            "enum": [
              "radio",
              "infrared",
              "anomaly"
            ]
          },
          "source_id": {
            "type": "string"
          },
          "extraction_status": {
            "enum": [
              "ready_for_extraction",
              "blocked",
              "no_candidate_expected",
              "scheduling_only"
            ]
          },
          "execution_mode": {
            "type": "string"
          },
          "ledger_run_id": {
            "type": "string"
          },
          "reviewed_workflow_status": {
            "enum": [
              "candidate_packet_ready",
              "local_scheduling_only",
              "negative_search_recorded",
              "review_blocked"
            ]
          },
          "required_inputs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "available_inputs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "expected_candidate_packet_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "candidate_fixture_path": {
            "type": [
              "string",
              "null"
            ]
          },
          "blocking_issues": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "negative_result_required": {
            "type": "boolean"
          },
          "requires_human_review": {
            "type": "boolean"
          },
          "network_access_allowed": {
            "const": false
          }
        }
      }
    }
  }
}
