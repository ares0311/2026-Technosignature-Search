{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "maintenance_log.schema.json",
  "title": "Maintenance Log",
  "description": "Operational provenance records for maintenance events.",
  "type": "object",
  "required": ["schema_version", "disclaimer", "entries"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "maintenance_log_v1"
    },
    "disclaimer": {
      "type": "string"
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/MaintenanceEntry"
      }
    }
  },
  "$defs": {
    "MaintenanceEntry": {
      "type": "object",
      "required": [
        "entry_id",
        "maintenance_kind",
        "status",
        "recorded_by",
        "timestamp_utc"
      ],
      "properties": {
        "entry_id": { "type": "string" },
        "maintenance_kind": {
          "type": "string",
          "enum": [
            "scheduled_maintenance",
            "emergency_repair",
            "calibration_service",
            "firmware_service",
            "inspection"
          ]
        },
        "status": {
          "type": "string",
          "enum": ["planned", "in_progress", "completed", "deferred"]
        },
        "recorded_by": { "type": "string" },
        "timestamp_utc": { "type": "string" },
        "component_id": {
          "oneOf": [{ "type": "string" }, { "type": "null" }]
        },
        "notes": {
          "oneOf": [{ "type": "string" }, { "type": "null" }]
        }
      },
      "additionalProperties": false
    }
  }
}
