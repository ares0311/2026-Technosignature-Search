{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/techno-search/validation_dataset_manifest.schema.json",
  "title": "Technosignature Search validation dataset manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "description",
    "disclaimer",
    "datasets"
  ],
  "properties": {
    "schema_version": {
      "const": "validation_dataset_manifest_v1"
    },
    "description": {
      "type": "string"
    },
    "disclaimer": {
      "type": "string"
    },
    "datasets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "dataset_id",
          "track",
          "dataset_kind",
          "readiness",
          "source_fixture_path",
          "case_count",
          "false_positive_classes",
          "expected_pathways"
        ],
        "properties": {
          "dataset_id": {
            "type": "string"
          },
          "track": {
            "enum": [
              "radio",
              "infrared",
              "anomaly"
            ]
          },
          "dataset_kind": {
            "type": "string"
          },
          "readiness": {
            "type": "string"
          },
          "source_fixture_path": {
            "type": "string"
          },
          "case_count": {
            "type": "integer",
            "minimum": 0
          },
          "false_positive_classes": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "expected_pathways": {
            "type": "array",
            "items": {
              "enum": [
                "known_object_annotation",
                "do_not_submit_false_positive",
                "github_reproducibility_only",
                "human_review_queue",
                "candidate_review_packet",
                "external_followup_candidate"
              ]
            },
            "uniqueItems": true
          }
        }
      }
    }
  }
}
