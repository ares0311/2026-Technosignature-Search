{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "incident_response_log.schema.json",
  "title": "Incident Response Log",
  "type": "object",
  "required": ["schema_version", "disclaimer", "entries"],
  "properties": {
    "schema_version": {"type": "string", "const": "incident_response_log_v1"},
    "disclaimer": {"type": "string"},
    "entries": {
      "type": "array",
      "items": {"$ref": "#/$defs/IncidentResponseEntry"}
    }
  },
  "$defs": {
    "IncidentResponseEntry": {
      "type": "object",
      "required": ["entry_id", "incident_kind", "status", "actor_id", "resource_id", "timestamp_utc"],
      "properties": {
        "entry_id": {"type": "string"},
        "incident_kind": {
          "type": "string",
          "enum": ["containment", "detection", "eradication", "lessons_learned", "recovery"]
        },
        "status": {
          "type": "string",
          "enum": ["closed", "contained", "open", "resolved"]
        },
        "actor_id": {"type": "string"},
        "resource_id": {"type": "string"},
        "timestamp_utc": {"type": "string"},
        "notes": {"oneOf": [{"type": "string"}, {"type": "null"}]}
      },
      "additionalProperties": false
    }
  }
}
