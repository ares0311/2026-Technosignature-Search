{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "compliance_report_log.schema.json",
  "title": "Compliance Report Log",
  "type": "object",
  "required": ["schema_version", "disclaimer", "entries"],
  "properties": {
    "schema_version": {"type": "string", "const": "compliance_report_log_v1"},
    "disclaimer": {"type": "string"},
    "entries": {
      "type": "array",
      "items": {"$ref": "#/$defs/ComplianceReportEntry"}
    }
  },
  "$defs": {
    "ComplianceReportEntry": {
      "type": "object",
      "required": ["entry_id", "report_kind", "status", "actor_id", "resource_id", "timestamp_utc"],
      "properties": {
        "entry_id": {"type": "string"},
        "report_kind": {
          "type": "string",
          "enum": ["certification_check", "external_audit", "internal_audit", "policy_review", "regulatory_report"]
        },
        "status": {
          "type": "string",
          "enum": ["failed", "passed", "pending", "waived"]
        },
        "actor_id": {"type": "string"},
        "resource_id": {"type": "string"},
        "timestamp_utc": {"type": "string"},
        "notes": {"oneOf": [{"type": "string"}, {"type": "null"}]}
      },
      "additionalProperties": false
    }
  }
}
