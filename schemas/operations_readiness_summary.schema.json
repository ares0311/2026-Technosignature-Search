{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OperationsReadinessSummary",
  "description": "Local-only operations readiness dashboard aggregating validation, review, SQLite log, and scheduling blockers. This summary does not authorize live data access or external submission.",
  "type": "object",
  "required": [
    "schema_version",
    "disclaimer",
    "recommendation",
    "local_validation_ready",
    "real_data_blocker_count",
    "operator_attention_count",
    "outstanding_blockers",
    "readiness_gates",
    "sqlite_log_snapshot"
  ],
  "properties": {
    "schema_version": {"const": "operations_readiness_v1"},
    "disclaimer": {"type": "string"},
    "recommendation": {
      "type": "string",
      "enum": ["local_only_ready", "operator_review_required", "blocked_for_real_data"]
    },
    "local_validation_ready": {"type": "boolean"},
    "real_data_blocker_count": {"type": "integer", "minimum": 0},
    "operator_attention_count": {"type": "integer", "minimum": 0},
    "outstanding_blockers": {
      "type": "array",
      "items": {"type": "string"}
    },
    "readiness_gates": {
      "type": "object",
      "required": [
        "route_coverage_complete",
        "sqlite_integrity_ok",
        "sqlite_weekly_digest_ok",
        "no_network_access_logged",
        "no_external_submission_approval_logged",
        "qc_not_blocked",
        "no_critical_open_alerts"
      ],
      "properties": {
        "route_coverage_complete": {"type": "boolean"},
        "sqlite_integrity_ok": {"type": "boolean"},
        "sqlite_weekly_digest_ok": {"type": "boolean"},
        "no_network_access_logged": {"type": "boolean"},
        "no_external_submission_approval_logged": {"type": "boolean"},
        "qc_not_blocked": {"type": "boolean"},
        "no_critical_open_alerts": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "qc_overall_health": {"type": "string"},
    "pipeline_capacity_status": {"type": "string"},
    "open_alert_count": {"type": "integer", "minimum": 0},
    "critical_open_alert_count": {"type": "integer", "minimum": 0},
    "overdue_review_deadline_count": {"type": "integer", "minimum": 0},
    "pipeline_health_blocked_count": {"type": "integer", "minimum": 0},
    "route_uncovered_pathway_count": {"type": "integer", "minimum": 0},
    "validation_readiness_blocking_issue_count": {"type": "integer", "minimum": 0},
    "curated_intake_blocking_issue_count": {"type": "integer", "minimum": 0},
    "submission_missing_provenance_field_count": {"type": "integer", "minimum": 0},
    "submission_blocking_issue_count": {"type": "integer", "minimum": 0},
    "external_submission_approved_count": {"type": "integer", "minimum": 0},
    "network_access_allowed_count": {"type": "integer", "minimum": 0},
    "sqlite_log_snapshot": {
      "type": "object",
      "required": [
        "present",
        "run_count",
        "network_access_allowed_count",
        "external_submission_approved_count",
        "integrity_ok",
        "weekly_digest_ok"
      ],
      "properties": {
        "log_path": {"type": ["string", "null"]},
        "present": {"type": "boolean"},
        "run_count": {"type": "integer", "minimum": 0},
        "network_access_allowed_count": {"type": "integer", "minimum": 0},
        "external_submission_approved_count": {"type": "integer", "minimum": 0},
        "integrity_ok": {"type": "boolean"},
        "weekly_digest_ok": {"type": "boolean"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
