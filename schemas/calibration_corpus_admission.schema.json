{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CalibrationCorpusAdmission",
  "description": "Admission records gating BL archive targets into the noise calibration corpus. Local readiness checks only — no real data ingestion, no scoring threshold modification.",
  "type": "object",
  "required": ["calibration_corpus_admission_records"],
  "properties": {
    "calibration_corpus_admission_records": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "corpus_id",
          "target_id",
          "source_label",
          "admission_status",
          "h5_downloaded",
          "turboseti_validated",
          "provenance_reviewed",
          "human_approval_status",
          "real_data_authorized",
          "blocker_count",
          "notes"
        ],
        "properties": {
          "corpus_id": { "type": "string" },
          "target_id": { "type": "string" },
          "source_label": { "type": "string" },
          "admission_status": {
            "type": "string",
            "enum": [
              "already_admitted",
              "blocked_pending_download",
              "blocked_pending_provenance",
              "blocked_pending_turboseti",
              "blocked_pending_review",
              "ready_for_local_calibration"
            ]
          },
          "h5_downloaded": { "type": "boolean" },
          "turboseti_validated": { "type": "boolean" },
          "provenance_reviewed": { "type": "boolean" },
          "human_approval_status": {
            "type": "string",
            "enum": ["approved", "pending", "blocked"]
          },
          "real_data_authorized": { "type": "boolean" },
          "blocker_count": { "type": "integer", "minimum": 0 },
          "notes": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
