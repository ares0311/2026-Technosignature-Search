{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "software_update_log.schema.json",
  "title": "Software Update Log",
  "description": "Operational provenance records for facility software and firmware update events.",
  "type": "object",
  "required": ["schema_version", "disclaimer", "entries"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "software_update_log_v1"
    },
    "disclaimer": {
      "type": "string"
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/SoftwareUpdateEntry"
      }
    }
  },
  "$defs": {
    "SoftwareUpdateEntry": {
      "type": "object",
      "required": [
        "entry_id",
        "update_kind",
        "status",
        "recorded_by",
        "timestamp_utc"
      ],
      "properties": {
        "entry_id": { "type": "string" },
        "update_kind": {
          "type": "string",
          "enum": [
            "pipeline_update",
            "firmware_update",
            "os_patch",
            "driver_update",
            "config_deploy"
          ]
        },
        "status": {
          "type": "string",
          "enum": ["deployed", "failed", "rolled_back", "pending"]
        },
        "recorded_by": { "type": "string" },
        "timestamp_utc": { "type": "string" },
        "component_id": {
          "oneOf": [{ "type": "string" }, { "type": "null" }]
        },
        "version_tag": {
          "oneOf": [{ "type": "string" }, { "type": "null" }]
        },
        "notes": {
          "oneOf": [{ "type": "string" }, { "type": "null" }]
        }
      },
      "additionalProperties": false
    }
  }
}
