{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StorageManagementLog",
  "description": "Operational provenance records for storage lifecycle events.",
  "type": "object",
  "required": ["schema_version", "disclaimer", "entries"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "storage_management_log_v1"
    },
    "disclaimer": {
      "type": "string"
    },
    "entries": {
      "type": "array",
      "items": { "$ref": "#/$defs/StorageManagementEntry" }
    }
  },
  "$defs": {
    "StorageManagementEntry": {
      "type": "object",
      "required": ["entry_id", "storage_kind", "status", "actor_id", "resource_id", "timestamp_utc"],
      "properties": {
        "entry_id": { "type": "string" },
        "storage_kind": {
          "type": "string",
          "enum": ["allocation", "cleanup", "deallocation", "migration", "quota_change"]
        },
        "status": {
          "type": "string",
          "enum": ["completed", "failed", "in_progress", "pending"]
        },
        "actor_id": { "type": "string" },
        "resource_id": { "type": "string" },
        "timestamp_utc": { "type": "string" },
        "notes": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
