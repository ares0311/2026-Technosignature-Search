{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/operations_blocker_progress_review.schema.json",
  "title": "Operations Blocker Progress Review Records",
  "type": "object",
  "required": [
    "schema_version",
    "disclaimer",
    "operations_blocker_progress_review_records"
  ],
  "properties": {
    "schema_version": {
      "const": "operations_blocker_progress_review_v1"
    },
    "disclaimer": {
      "type": "string",
      "minLength": 1
    },
    "operations_blocker_progress_review_records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "review_id",
          "action_id",
          "progress_id",
          "category",
          "progress_status",
          "review_status",
          "operator_id",
          "reviewed_utc",
          "review_note",
          "residual_blocker_count",
          "live_data_authorized",
          "external_submission_authorized"
        ],
        "properties": {
          "review_id": {
            "type": "string",
            "minLength": 1
          },
          "action_id": {
            "type": "string",
            "minLength": 1
          },
          "progress_id": {
            "type": "string",
            "minLength": 1
          },
          "category": {
            "type": "string",
            "enum": [
              "alerts",
              "capacity",
              "curated_intake",
              "external_submission",
              "network_access",
              "pipeline_health",
              "quality_control",
              "review_deadlines",
              "route_coverage",
              "sqlite_logs",
              "submission_provenance",
              "validation_readiness"
            ]
          },
          "progress_status": {
            "type": "string",
            "enum": [
              "blocked",
              "in_progress",
              "not_started",
              "ready_for_local_verification",
              "waiting_for_real_data"
            ]
          },
          "review_status": {
            "type": "string",
            "enum": [
              "blocked_for_real_data",
              "needs_operator_action",
              "ready_for_next_local_note",
              "verified_no_action",
              "waiting_on_policy"
            ]
          },
          "operator_id": {
            "type": "string",
            "minLength": 1
          },
          "reviewed_utc": {
            "type": "string",
            "format": "date-time"
          },
          "review_note": {
            "type": "string",
            "minLength": 1
          },
          "residual_blocker_count": {
            "type": "integer",
            "minimum": 0
          },
          "live_data_authorized": {
            "type": "boolean"
          },
          "external_submission_authorized": {
            "type": "boolean"
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
