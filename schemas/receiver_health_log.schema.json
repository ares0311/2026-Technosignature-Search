{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ReceiverHealthLog",
  "description": "Operational scheduling provenance records for receiver health checks.",
  "type": "object",
  "required": ["schema_version", "entries"],
  "properties": {
    "schema_version": {"type": "string"},
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "entry_id", "run_id",
          "health_kind", "status", "checked_by", "checked_at"
        ],
        "properties": {
          "entry_id": {"type": "string"},
          "run_id": {"type": "string"},
          "health_kind": {
            "type": "string",
            "enum": [
              "gain_stability",
              "noise_temperature",
              "bandpass_flatness",
              "pointing_accuracy",
              "focus_setting"
            ]
          },
          "status": {
            "type": "string",
            "enum": ["nominal", "degraded", "critical", "maintenance_required"]
          },
          "checked_by": {"type": "string"},
          "checked_at": {"type": "string"},
          "metric_value": {"type": ["number", "null"]},
          "threshold_value": {"type": ["number", "null"]},
          "notes": {"type": ["string", "null"]}
        }
      }
    }
  }
}
