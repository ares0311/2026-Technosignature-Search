{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TargetSelectionLog",
  "description": "Operational scheduling provenance records for target selection events.",
  "type": "object",
  "required": ["schema_version", "entries"],
  "properties": {
    "schema_version": {"type": "string"},
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "entry_id", "candidate_id", "track",
          "selection_kind", "status", "selected_by", "selected_at"
        ],
        "properties": {
          "entry_id": {"type": "string"},
          "candidate_id": {"type": "string"},
          "track": {"type": "string"},
          "selection_kind": {
            "type": "string",
            "enum": [
              "priority_queue", "manual_selection", "automated_filter",
              "watchlist_trigger", "follow_up_request"
            ]
          },
          "status": {
            "type": "string",
            "enum": ["selected", "deferred", "rejected", "pending"]
          },
          "selected_by": {"type": "string"},
          "selected_at": {"type": "string"},
          "priority_score": {"type": ["number", "null"]},
          "reason": {"type": ["string", "null"]},
          "notes": {"type": ["string", "null"]}
        }
      }
    }
  }
}
