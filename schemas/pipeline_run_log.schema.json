{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PipelineRunLog",
  "description": "Operational reproducibility records for top-level pipeline execution runs.",
  "type": "object",
  "required": ["pipeline_run_entries"],
  "properties": {
    "pipeline_run_entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["entry_id","run_id","run_kind","status","started_by","started_at"],
        "properties": {
          "entry_id": {"type": "string"},
          "run_id": {"type": "string"},
          "run_kind": {"type": "string", "enum": ["full_pipeline","partial_rerun","calibration_only","test_run","recovery_run"]},
          "status": {"type": "string", "enum": ["started","completed","failed","aborted","paused"]},
          "started_by": {"type": "string"},
          "started_at": {"type": "string"},
          "completed_at": {"type": ["string","null"]},
          "candidate_count": {"type": ["integer","null"]},
          "notes": {"type": ["string","null"]}
        }
      }
    }
  }
}
