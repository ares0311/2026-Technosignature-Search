{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "HealthCheckLog",
  "description": "Operational provenance records for system and service health check events.",
  "type": "object",
  "required": ["schema_version", "disclaimer", "entries"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "health_check_log_v1"
    },
    "disclaimer": {
      "type": "string"
    },
    "entries": {
      "type": "array",
      "items": { "$ref": "#/$defs/HealthCheckEntry" }
    }
  },
  "$defs": {
    "HealthCheckEntry": {
      "type": "object",
      "required": ["entry_id", "check_kind", "status", "actor_id", "resource_id", "timestamp_utc"],
      "properties": {
        "entry_id": { "type": "string" },
        "check_kind": {
          "type": "string",
          "enum": ["api_health", "database_health", "network_health", "service_health", "storage_health"]
        },
        "status": {
          "type": "string",
          "enum": ["degraded", "failed", "passed", "timeout"]
        },
        "actor_id": { "type": "string" },
        "resource_id": { "type": "string" },
        "timestamp_utc": { "type": "string" },
        "notes": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
