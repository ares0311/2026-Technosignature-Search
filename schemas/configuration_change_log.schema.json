{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ConfigurationChangeLog",
  "type": "object",
  "required": ["schema_version", "entries"],
  "properties": {
    "schema_version": { "type": "string" },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["entry_id", "change_kind", "status", "actor_id", "resource_id", "timestamp_utc", "notes"],
        "properties": {
          "entry_id": { "type": "string" },
          "change_kind": {
            "type": "string",
            "enum": ["parameter_update", "profile_switch", "rollback", "template_apply", "version_pin"]
          },
          "status": {
            "type": "string",
            "enum": ["applied", "failed", "pending", "reverted"]
          },
          "actor_id": { "type": "string" },
          "resource_id": { "type": "string" },
          "timestamp_utc": { "type": "string" },
          "notes": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
