{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "time_synchronization_log.schema.json",
  "title": "Time Synchronization Log",
  "description": "Operational provenance records for time and clock synchronization events.",
  "type": "object",
  "required": ["schema_version", "disclaimer", "entries"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "time_synchronization_log_v1"
    },
    "disclaimer": {
      "type": "string"
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/TimeSynchronizationEntry"
      }
    }
  },
  "$defs": {
    "TimeSynchronizationEntry": {
      "type": "object",
      "required": [
        "entry_id",
        "sync_kind",
        "status",
        "recorded_by",
        "recorded_at"
      ],
      "properties": {
        "entry_id": { "type": "string" },
        "sync_kind": {
          "type": "string",
          "enum": [
            "ntp_sync",
            "gps_sync",
            "manual_correction",
            "drift_check",
            "epoch_reset"
          ]
        },
        "status": {
          "type": "string",
          "enum": ["synchronized", "drifted", "failed", "not_required"]
        },
        "recorded_by": { "type": "string" },
        "recorded_at": { "type": "string" },
        "offset_microseconds": {
          "oneOf": [{ "type": "number" }, { "type": "null" }]
        },
        "drift_rate_ppb": {
          "oneOf": [{ "type": "number" }, { "type": "null" }]
        },
        "notes": {
          "oneOf": [{ "type": "string" }, { "type": "null" }]
        }
      },
      "additionalProperties": false
    }
  }
}
