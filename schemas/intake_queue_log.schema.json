{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Intake Queue Log",
  "type": "object",
  "required": ["schema_version", "intake_queue_entries"],
  "properties": {
    "schema_version": { "type": "string", "const": "intake_queue_log_v1" },
    "intake_queue_entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "intake_id", "source_kind", "source_description", "status",
          "queue_position", "requested_by", "requested_utc"
        ],
        "properties": {
          "intake_id": { "type": "string" },
          "source_kind": {
            "type": "string",
            "enum": ["radio_survey", "infrared_catalog", "archival_image", "spectral_archive", "unknown"]
          },
          "source_description": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["queued", "blocked", "intake_ready", "intake_complete", "cancelled"]
          },
          "queue_position": { "type": "integer" },
          "requested_by": { "type": "string" },
          "requested_utc": { "type": "string" },
          "blocking_reason": { "type": ["string", "null"] },
          "intake_utc": { "type": ["string", "null"] },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
