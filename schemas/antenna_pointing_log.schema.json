{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "antenna_pointing_log.schema.json",
  "title": "Antenna Pointing Log",
  "description": "Operational provenance records for antenna pointing and slew events.",
  "type": "object",
  "required": ["schema_version", "disclaimer", "entries"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "antenna_pointing_log_v1"
    },
    "disclaimer": {
      "type": "string"
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/AntennaPointingEntry"
      }
    }
  },
  "$defs": {
    "AntennaPointingEntry": {
      "type": "object",
      "required": [
        "entry_id",
        "pointing_kind",
        "status",
        "recorded_by",
        "timestamp_utc"
      ],
      "properties": {
        "entry_id": { "type": "string" },
        "pointing_kind": {
          "type": "string",
          "enum": [
            "target_slew",
            "park_position",
            "stow_position",
            "tracking_start",
            "tracking_end"
          ]
        },
        "status": {
          "type": "string",
          "enum": ["completed", "failed", "timeout", "cancelled"]
        },
        "recorded_by": { "type": "string" },
        "timestamp_utc": { "type": "string" },
        "target_id": {
          "oneOf": [{ "type": "string" }, { "type": "null" }]
        },
        "azimuth_deg": {
          "oneOf": [{ "type": "number" }, { "type": "null" }]
        },
        "elevation_deg": {
          "oneOf": [{ "type": "number" }, { "type": "null" }]
        },
        "notes": {
          "oneOf": [{ "type": "string" }, { "type": "null" }]
        }
      },
      "additionalProperties": false
    }
  }
}
