{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/techno-search/background_targets.schema.json",
  "title": "Technosignature Search background target priority list",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "description",
    "disclaimer",
    "targets"
  ],
  "properties": {
    "schema_version": {
      "const": "background_target_priority_v1"
    },
    "description": {
      "type": "string"
    },
    "disclaimer": {
      "type": "string"
    },
    "targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "target_id",
          "track",
          "source_id",
          "followup_value",
          "novelty_score",
          "data_quality_score",
          "observability_score",
          "false_positive_probability",
          "blocking_issue_count"
        ],
        "properties": {
          "target_id": {
            "type": "string"
          },
          "track": {
            "enum": [
              "radio",
              "infrared",
              "anomaly"
            ]
          },
          "source_id": {
            "type": "string"
          },
          "followup_value": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "novelty_score": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "data_quality_score": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "observability_score": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "false_positive_probability": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "blocking_issue_count": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    }
  }
}
