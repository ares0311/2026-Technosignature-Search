{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PolarizationLog",
  "description": "Operational processing provenance records for polarization measurements.",
  "type": "object",
  "required": ["polarization_entries"],
  "properties": {
    "polarization_entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["entry_id","run_id","polarization_kind","status","measured_by","measured_at"],
        "properties": {
          "entry_id": {"type": "string"},
          "run_id": {"type": "string"},
          "polarization_kind": {"type": "string", "enum": ["stokes_i","stokes_q","stokes_u","stokes_v","circular_polarization"]},
          "status": {"type": "string", "enum": ["measured","calibrated","flagged","failed"]},
          "measured_by": {"type": "string"},
          "measured_at": {"type": "string"},
          "fractional_polarization": {"type": ["number","null"]},
          "position_angle_deg": {"type": ["number","null"]},
          "notes": {"type": ["string","null"]}
        }
      }
    }
  }
}
