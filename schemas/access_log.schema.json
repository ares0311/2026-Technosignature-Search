{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "access_log.schema.json",
  "title": "Access Log",
  "description": "Operational provenance records for facility and system access events.",
  "type": "object",
  "required": ["schema_version", "disclaimer", "entries"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "access_log_v1"
    },
    "disclaimer": {
      "type": "string"
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/AccessEntry"
      }
    }
  },
  "$defs": {
    "AccessEntry": {
      "type": "object",
      "required": [
        "entry_id",
        "access_kind",
        "status",
        "actor_id",
        "resource_id",
        "timestamp_utc"
      ],
      "properties": {
        "entry_id": { "type": "string" },
        "access_kind": {
          "type": "string",
          "enum": [
            "facility_entry",
            "facility_exit",
            "remote_access",
            "system_login",
            "system_logout"
          ]
        },
        "status": {
          "type": "string",
          "enum": ["denied", "expired", "granted", "revoked"]
        },
        "actor_id": { "type": "string" },
        "resource_id": { "type": "string" },
        "timestamp_utc": { "type": "string" },
        "notes": {
          "oneOf": [{ "type": "string" }, { "type": "null" }]
        }
      },
      "additionalProperties": false
    }
  }
}
