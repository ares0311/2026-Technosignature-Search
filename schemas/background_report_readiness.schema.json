{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/techno-search/background_report_readiness.schema.json",
  "title": "Technosignature Search background report-readiness gates",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "description",
    "disclaimer",
    "readiness_records"
  ],
  "properties": {
    "schema_version": {
      "const": "background_report_readiness_v1"
    },
    "description": {
      "type": "string"
    },
    "disclaimer": {
      "type": "string"
    },
    "readiness_records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "readiness_id",
          "follow_up_id",
          "run_id",
          "target_id",
          "track",
          "readiness_status",
          "evaluated_at_utc",
          "mandatory_tests_complete",
          "ready_to_draft_report",
          "report_required",
          "user_approval_required",
          "external_submission_allowed",
          "recommended_action",
          "blocking_issues",
          "limitations",
          "top_three_recommendations",
          "network_access_allowed"
        ],
        "properties": {
          "readiness_id": {
            "type": "string"
          },
          "follow_up_id": {
            "type": "string"
          },
          "run_id": {
            "type": "string"
          },
          "target_id": {
            "type": "string"
          },
          "track": {
            "enum": [
              "radio",
              "infrared",
              "anomaly"
            ]
          },
          "readiness_status": {
            "enum": [
              "ready_for_draft_report",
              "blocked_pending_tests",
              "not_report_ready"
            ]
          },
          "evaluated_at_utc": {
            "type": "string"
          },
          "mandatory_tests_complete": {
            "type": "boolean"
          },
          "ready_to_draft_report": {
            "type": "boolean"
          },
          "report_required": {
            "type": "boolean"
          },
          "user_approval_required": {
            "const": true
          },
          "external_submission_allowed": {
            "const": false
          },
          "recommended_action": {
            "enum": [
              "draft_internal_review_report",
              "request_more_tests",
              "do_not_submit_yet"
            ]
          },
          "blocking_issues": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "limitations": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "top_three_recommendations": {
            "type": "array",
            "minItems": 3,
            "maxItems": 3,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "rank",
                "destination",
                "suitability_rationale",
                "risks",
                "prerequisites",
                "recommended_action"
              ],
              "properties": {
                "rank": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 3
                },
                "destination": {
                  "type": "string"
                },
                "suitability_rationale": {
                  "type": "string"
                },
                "risks": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "prerequisites": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "recommended_action": {
                  "enum": [
                    "internal_review",
                    "request_more_tests",
                    "do_not_submit_yet"
                  ]
                }
              }
            }
          },
          "network_access_allowed": {
            "const": false
          }
        }
      }
    }
  }
}
