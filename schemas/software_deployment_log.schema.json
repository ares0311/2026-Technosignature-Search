{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "software_deployment_log.schema.json",
  "title": "Software Deployment Log",
  "type": "object",
  "required": ["schema_version", "disclaimer", "entries"],
  "properties": {
    "schema_version": {"type": "string", "const": "software_deployment_log_v1"},
    "disclaimer": {"type": "string"},
    "entries": {
      "type": "array",
      "items": {"$ref": "#/$defs/SoftwareDeploymentEntry"}
    }
  },
  "additionalProperties": false,
  "$defs": {
    "SoftwareDeploymentEntry": {
      "type": "object",
      "required": ["entry_id", "deployment_kind", "status", "actor_id", "resource_id", "timestamp_utc"],
      "properties": {
        "entry_id": {"type": "string"},
        "deployment_kind": {
          "type": "string",
          "enum": ["hotfix", "major_release", "minor_release", "patch", "rollback"]
        },
        "status": {
          "type": "string",
          "enum": ["completed", "failed", "in_progress", "rolled_back"]
        },
        "actor_id": {"type": "string"},
        "resource_id": {"type": "string"},
        "timestamp_utc": {"type": "string"},
        "notes": {"oneOf": [{"type": "string"}, {"type": "null"}]}
      },
      "additionalProperties": false
    }
  }
}
