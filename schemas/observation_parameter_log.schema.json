{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ObservationParameterLog",
  "description": "Operational processing provenance records for observation configuration parameters.",
  "type": "object",
  "required": ["observation_parameter_entries"],
  "properties": {
    "observation_parameter_entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["entry_id","run_id","parameter_kind","status","set_by","set_at"],
        "properties": {
          "entry_id": {"type": "string"},
          "run_id": {"type": "string"},
          "parameter_kind": {"type": "string", "enum": ["integration_time","bandwidth","center_frequency","resolution","sensitivity_target"]},
          "status": {"type": "string", "enum": ["applied","overridden","flagged","failed"]},
          "set_by": {"type": "string"},
          "set_at": {"type": "string"},
          "value": {"type": ["number","null"]},
          "unit": {"type": ["string","null"]},
          "notes": {"type": ["string","null"]}
        }
      }
    }
  }
}
