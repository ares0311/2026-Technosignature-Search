{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/operations_blocker_review.schema.json",
  "title": "Operations Blocker Review Records",
  "type": "object",
  "required": [
    "operations_blocker_review_records"
  ],
  "properties": {
    "schema_version": {
      "const": "operations_blocker_review_v1"
    },
    "disclaimer": {
      "type": "string",
      "minLength": 1
    },
    "operations_blocker_review_records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "review_id",
          "action_id",
          "category",
          "review_status",
          "operator_id",
          "review_utc",
          "evidence_record_count",
          "reviewed_evidence_record_count",
          "evidence_note",
          "residual_blocker_count",
          "live_data_authorized",
          "external_submission_authorized"
        ],
        "properties": {
          "review_id": {
            "type": "string",
            "minLength": 1
          },
          "action_id": {
            "type": "string",
            "minLength": 1
          },
          "category": {
            "type": "string",
            "enum": [
              "alerts",
              "capacity",
              "curated_intake",
              "external_submission",
              "network_access",
              "pipeline_health",
              "quality_control",
              "review_deadlines",
              "route_coverage",
              "sqlite_logs",
              "submission_provenance",
              "validation_readiness"
            ]
          },
          "review_status": {
            "type": "string",
            "enum": [
              "acknowledged",
              "blocked_for_real_data",
              "deferred",
              "open",
              "resolved"
            ]
          },
          "operator_id": {
            "type": "string",
            "minLength": 1
          },
          "review_utc": {
            "type": "string",
            "format": "date-time"
          },
          "evidence_record_count": {
            "type": "integer",
            "minimum": 0
          },
          "reviewed_evidence_record_count": {
            "type": "integer",
            "minimum": 0
          },
          "evidence_note": {
            "type": "string",
            "minLength": 1
          },
          "residual_blocker_count": {
            "type": "integer",
            "minimum": 0
          },
          "live_data_authorized": {
            "type": "boolean"
          },
          "external_submission_authorized": {
            "type": "boolean"
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
