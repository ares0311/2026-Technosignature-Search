{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "environmental_log.schema.json",
  "title": "Environmental Log",
  "description": "Operational provenance records for environmental monitoring events.",
  "type": "object",
  "required": ["schema_version", "disclaimer", "entries"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "environmental_log_v1"
    },
    "disclaimer": {
      "type": "string"
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/EnvironmentalEntry"
      }
    }
  },
  "$defs": {
    "EnvironmentalEntry": {
      "type": "object",
      "required": [
        "entry_id",
        "environment_kind",
        "status",
        "recorded_by",
        "timestamp_utc"
      ],
      "properties": {
        "entry_id": { "type": "string" },
        "environment_kind": {
          "type": "string",
          "enum": [
            "temperature_reading",
            "humidity_reading",
            "pressure_reading",
            "vibration_reading",
            "electromagnetic_interference"
          ]
        },
        "status": {
          "type": "string",
          "enum": ["nominal", "advisory", "warning", "critical"]
        },
        "recorded_by": { "type": "string" },
        "timestamp_utc": { "type": "string" },
        "component_id": {
          "oneOf": [{ "type": "string" }, { "type": "null" }]
        },
        "notes": {
          "oneOf": [{ "type": "string" }, { "type": "null" }]
        }
      },
      "additionalProperties": false
    }
  }
}
