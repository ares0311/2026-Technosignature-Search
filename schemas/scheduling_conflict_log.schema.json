{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SchedulingConflictLog",
  "description": "Operational provenance records for scheduling conflict events. Conflict records do not modify candidate scores or pathway routing, do not authorize external submission, and do not constitute detection claims.",
  "type": "object",
  "required": ["schema_version", "disclaimer", "entries"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "scheduling_conflict_log_v1"
    },
    "disclaimer": {
      "type": "string"
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "entry_id",
          "conflict_kind",
          "status",
          "detected_by",
          "detected_at"
        ],
        "properties": {
          "entry_id": { "type": "string" },
          "conflict_kind": {
            "type": "string",
            "enum": [
              "time_slot_overlap",
              "resource_contention",
              "priority_conflict",
              "maintenance_window",
              "weather_hold"
            ]
          },
          "status": {
            "type": "string",
            "enum": ["detected", "resolved", "escalated", "deferred"]
          },
          "detected_by": { "type": "string" },
          "detected_at": { "type": "string" },
          "affected_candidate_id": {
            "oneOf": [{ "type": "string" }, { "type": "null" }]
          },
          "track": {
            "oneOf": [{ "type": "string" }, { "type": "null" }]
          },
          "resolution_note": {
            "oneOf": [{ "type": "string" }, { "type": "null" }]
          },
          "resolved_at": {
            "oneOf": [{ "type": "string" }, { "type": "null" }]
          },
          "notes": {
            "oneOf": [{ "type": "string" }, { "type": "null" }]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
