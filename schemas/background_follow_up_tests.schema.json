{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/techno-search/background_follow_up_tests.schema.json",
  "title": "Technosignature Search background follow-up test results",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "description",
    "disclaimer",
    "test_results"
  ],
  "properties": {
    "schema_version": {
      "const": "background_follow_up_tests_v1"
    },
    "description": {
      "type": "string"
    },
    "disclaimer": {
      "type": "string"
    },
    "test_results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "result_id",
          "follow_up_id",
          "run_id",
          "target_id",
          "track",
          "test_name",
          "status",
          "executed_at_utc",
          "evidence",
          "negative_evidence",
          "blocking_issues",
          "uncertainty_notes",
          "network_access_allowed"
        ],
        "properties": {
          "result_id": {
            "type": "string"
          },
          "follow_up_id": {
            "type": "string"
          },
          "run_id": {
            "type": "string"
          },
          "target_id": {
            "type": "string"
          },
          "track": {
            "enum": [
              "radio",
              "infrared",
              "anomaly"
            ]
          },
          "test_name": {
            "enum": [
              "provenance_check",
              "false_positive_class_check",
              "cross_source_consistency_check",
              "calibration_confidence_check",
              "reproducibility_check",
              "human_review_checklist"
            ]
          },
          "status": {
            "enum": [
              "pass",
              "fail",
              "blocked",
              "uncertain",
              "ready"
            ]
          },
          "executed_at_utc": {
            "type": "string"
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "negative_evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "blocking_issues": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "uncertainty_notes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "network_access_allowed": {
            "const": false
          }
        }
      }
    }
  }
}
