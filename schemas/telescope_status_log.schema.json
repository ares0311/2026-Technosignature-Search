{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TelescopeStatusLog",
  "description": "Operational scheduling provenance records for telescope operational status.",
  "type": "object",
  "required": ["telescope_status_entries"],
  "properties": {
    "telescope_status_entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["entry_id","run_id","status_kind","status","recorded_by","recorded_at"],
        "properties": {
          "entry_id": {"type": "string"},
          "run_id": {"type": "string"},
          "status_kind": {"type": "string", "enum": ["operational","maintenance","degraded","offline","commissioning"]},
          "status": {"type": "string", "enum": ["recorded","updated","superseded","error"]},
          "recorded_by": {"type": "string"},
          "recorded_at": {"type": "string"},
          "telescope_id": {"type": ["string","null"]},
          "affected_tracks": {"type": "array", "items": {"type": "string"}},
          "notes": {"type": ["string","null"]}
        }
      }
    }
  }
}
