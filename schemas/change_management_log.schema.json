{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "change_management_log.schema.json",
  "title": "Change Management Log",
  "type": "object",
  "required": ["schema_version", "disclaimer", "entries"],
  "properties": {
    "schema_version": {"type": "string", "const": "change_management_log_v1"},
    "disclaimer": {"type": "string"},
    "entries": {
      "type": "array",
      "items": {"$ref": "#/$defs/ChangeManagementEntry"}
    }
  },
  "$defs": {
    "ChangeManagementEntry": {
      "type": "object",
      "required": ["entry_id", "change_kind", "status", "actor_id", "resource_id", "timestamp_utc"],
      "properties": {
        "entry_id": {"type": "string"},
        "change_kind": {
          "type": "string",
          "enum": ["approval_request", "emergency_change", "planned_change", "rejection", "rollback"]
        },
        "status": {
          "type": "string",
          "enum": ["approved", "implemented", "requested", "rolled_back"]
        },
        "actor_id": {"type": "string"},
        "resource_id": {"type": "string"},
        "timestamp_utc": {"type": "string"},
        "notes": {"oneOf": [{"type": "string"}, {"type": "null"}]}
      },
      "additionalProperties": false
    }
  }
}
