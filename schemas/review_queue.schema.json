{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/techno-search/review_queue.schema.json",
  "title": "Technosignature Search human-review queue packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "description",
    "disclaimer",
    "allowed_triage_labels",
    "items"
  ],
  "properties": {
    "schema_version": {
      "const": "human_review_queue_v1"
    },
    "description": {
      "type": "string"
    },
    "disclaimer": {
      "type": "string"
    },
    "allowed_triage_labels": {
      "type": "array",
      "items": {
        "enum": [
          "follow_up_target",
          "insufficient_evidence",
          "known_object_annotation",
          "likely_false_positive",
          "needs_human_review"
        ]
      },
      "minItems": 5,
      "uniqueItems": true
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "candidate_id",
          "track",
          "recommended_pathway",
          "triage_label",
          "source_packet_path",
          "review_packet_path",
          "negative_evidence_count",
          "blocking_issue_count",
          "reviewer_notes"
        ],
        "properties": {
          "candidate_id": {
            "type": "string"
          },
          "track": {
            "enum": [
              "radio",
              "infrared",
              "anomaly"
            ]
          },
          "recommended_pathway": {
            "enum": [
              "known_object_annotation",
              "do_not_submit_false_positive",
              "github_reproducibility_only",
              "human_review_queue",
              "candidate_review_packet",
              "external_followup_candidate"
            ]
          },
          "triage_label": {
            "enum": [
              "follow_up_target",
              "insufficient_evidence",
              "known_object_annotation",
              "likely_false_positive",
              "needs_human_review"
            ]
          },
          "source_packet_path": {
            "type": "string"
          },
          "review_packet_path": {
            "type": "string"
          },
          "negative_evidence_count": {
            "type": "integer",
            "minimum": 0
          },
          "blocking_issue_count": {
            "type": "integer",
            "minimum": 0
          },
          "reviewer_notes": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "reviewer_id",
                "created_at_utc",
                "note",
                "tags"
              ],
              "properties": {
                "reviewer_id": {
                  "type": "string"
                },
                "created_at_utc": {
                  "type": "string"
                },
                "note": {
                  "type": "string"
                },
                "tags": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "uniqueItems": true
                }
              }
            }
          }
        }
      }
    }
  }
}
