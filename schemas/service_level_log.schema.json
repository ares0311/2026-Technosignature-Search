{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ServiceLevelLog",
  "description": "Operational provenance records for service level events.",
  "type": "object",
  "required": ["schema_version", "entries"],
  "properties": {
    "schema_version": {"type": "string"},
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["entry_id", "level_kind", "status", "actor_id", "resource_id", "timestamp_utc"],
        "properties": {
          "entry_id": {"type": "string"},
          "level_kind": {"type": "string", "enum": ["availability_check", "compliance_check", "error_rate_check", "latency_check", "throughput_check"]},
          "status": {"type": "string", "enum": ["at_risk", "met", "missed", "not_applicable"]},
          "actor_id": {"type": "string"},
          "resource_id": {"type": "string"},
          "timestamp_utc": {"type": "string"},
          "notes": {"type": ["string", "null"]}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
