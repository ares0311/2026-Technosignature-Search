{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/operations_blocker_followup_progress.schema.json",
  "title": "Operations Blocker Followup Progress Records",
  "type": "object",
  "required": [
    "schema_version",
    "disclaimer",
    "operations_blocker_followup_progress_records"
  ],
  "properties": {
    "schema_version": {
      "const": "operations_blocker_followup_progress_v1"
    },
    "disclaimer": {
      "type": "string",
      "minLength": 1
    },
    "operations_blocker_followup_progress_records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "progress_id",
          "action_id",
          "category",
          "recommendation",
          "progress_status",
          "operator_id",
          "progress_utc",
          "evidence_note",
          "residual_blocker_count",
          "live_data_authorized",
          "external_submission_authorized"
        ],
        "properties": {
          "progress_id": {
            "type": "string",
            "minLength": 1
          },
          "action_id": {
            "type": "string",
            "minLength": 1
          },
          "category": {
            "type": "string",
            "enum": [
              "alerts",
              "capacity",
              "curated_intake",
              "external_submission",
              "network_access",
              "pipeline_health",
              "quality_control",
              "review_deadlines",
              "route_coverage",
              "sqlite_logs",
              "submission_provenance",
              "validation_readiness"
            ]
          },
          "recommendation": {
            "type": "string",
            "enum": [
              "continue_local_remediation",
              "halt_for_authorization_review",
              "hold_for_real_data_evidence",
              "monitor_deferred_item",
              "operator_attention_required",
              "reopen_residual_blockers",
              "verify_resolved_locally"
            ]
          },
          "progress_status": {
            "type": "string",
            "enum": [
              "blocked",
              "in_progress",
              "not_started",
              "ready_for_local_verification",
              "verified_local",
              "waiting_for_real_data"
            ]
          },
          "operator_id": {
            "type": "string",
            "minLength": 1
          },
          "progress_utc": {
            "type": "string",
            "format": "date-time"
          },
          "evidence_note": {
            "type": "string",
            "minLength": 1
          },
          "residual_blocker_count": {
            "type": "integer",
            "minimum": 0
          },
          "live_data_authorized": {
            "type": "boolean"
          },
          "external_submission_authorized": {
            "type": "boolean"
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
