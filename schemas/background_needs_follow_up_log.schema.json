{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/techno-search/background_needs_follow_up_log.schema.json",
  "title": "Technosignature Search needs-follow-up background-search log",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "description",
    "disclaimer",
    "needs_follow_up_entries"
  ],
  "properties": {
    "schema_version": {
      "const": "background_needs_follow_up_log_v1"
    },
    "description": {
      "type": "string"
    },
    "disclaimer": {
      "type": "string"
    },
    "needs_follow_up_entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "follow_up_id",
          "run_id",
          "target_id",
          "track",
          "follow_up_status",
          "created_at_utc",
          "trigger_types",
          "reason_codes",
          "required_tests",
          "blocking_issues",
          "report_required",
          "human_review_required",
          "submission_requires_user_approval",
          "network_access_allowed"
        ],
        "properties": {
          "follow_up_id": {
            "type": "string"
          },
          "run_id": {
            "type": "string"
          },
          "target_id": {
            "type": "string"
          },
          "track": {
            "enum": [
              "radio",
              "infrared",
              "anomaly"
            ]
          },
          "follow_up_status": {
            "const": "needs_follow_up_required"
          },
          "created_at_utc": {
            "type": "string"
          },
          "trigger_types": {
            "type": "array",
            "minItems": 1,
            "items": {
              "enum": [
                "quantitative_threshold",
                "rule_based_blocking_issue",
                "rule_based_provenance_gap",
                "rule_based_calibration_gap"
              ]
            }
          },
          "reason_codes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "required_tests": {
            "type": "array",
            "minItems": 6,
            "items": {
              "enum": [
                "provenance_check",
                "false_positive_class_check",
                "cross_source_consistency_check",
                "calibration_confidence_check",
                "reproducibility_check",
                "human_review_checklist"
              ]
            }
          },
          "blocking_issues": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "report_required": {
            "type": "boolean"
          },
          "human_review_required": {
            "const": true
          },
          "submission_requires_user_approval": {
            "const": true
          },
          "network_access_allowed": {
            "const": false
          }
        }
      }
    }
  }
}
