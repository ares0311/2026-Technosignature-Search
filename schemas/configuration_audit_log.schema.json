{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ConfigurationAuditLog",
  "description": "Operational provenance records for configuration change audit events.",
  "type": "object",
  "required": ["schema_version", "disclaimer", "entries"],
  "properties": {
    "schema_version": { "type": "string", "const": "configuration_audit_log_v1" },
    "disclaimer": { "type": "string" },
    "entries": { "type": "array", "items": { "$ref": "#/$defs/ConfigurationAuditEntry" } }
  },
  "$defs": {
    "ConfigurationAuditEntry": {
      "type": "object",
      "required": ["entry_id", "audit_kind", "status", "actor_id", "resource_id", "timestamp_utc"],
      "properties": {
        "entry_id": { "type": "string" },
        "audit_kind": {
          "type": "string",
          "enum": ["baseline_check", "compliance_scan", "drift_detection", "manual_audit", "scheduled_audit"]
        },
        "status": { "type": "string", "enum": ["compliant", "drifted", "failed", "inconclusive"] },
        "actor_id": { "type": "string" },
        "resource_id": { "type": "string" },
        "timestamp_utc": { "type": "string" },
        "notes": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
