{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "QualityGateLog",
  "type": "object",
  "required": ["schema_version", "quality_gate_entries"],
  "properties": {
    "schema_version": {"type": "string"},
    "quality_gate_entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["gate_id", "candidate_id", "gate_kind", "result", "checked_by", "checked_utc"],
        "properties": {
          "gate_id": {"type": "string"},
          "candidate_id": {"type": "string"},
          "gate_kind": {
            "type": "string",
            "enum": ["score_threshold", "provenance_completeness", "rfi_screen", "catalog_check", "review_coverage"]
          },
          "result": {
            "type": "string",
            "enum": ["pass", "fail", "warn", "not_applicable"]
          },
          "checked_by": {"type": "string"},
          "checked_utc": {"type": "string"},
          "score_at_check": {"type": ["number", "null"]},
          "notes": {"type": "string"}
        }
      }
    }
  }
}
