{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "NetworkMonitoringLog",
  "description": "Operational provenance records for network monitoring events.",
  "type": "object",
  "required": ["schema_version", "entries"],
  "properties": {
    "schema_version": {"type": "string"},
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["entry_id", "network_kind", "status", "actor_id", "resource_id", "timestamp_utc"],
        "properties": {
          "entry_id": {"type": "string"},
          "network_kind": {"type": "string", "enum": ["bandwidth_check", "connectivity_check", "latency_probe", "packet_loss_check", "routing_check"]},
          "status": {"type": "string", "enum": ["alert", "degraded", "healthy", "unreachable"]},
          "actor_id": {"type": "string"},
          "resource_id": {"type": "string"},
          "timestamp_utc": {"type": "string"},
          "notes": {"type": ["string", "null"]}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
