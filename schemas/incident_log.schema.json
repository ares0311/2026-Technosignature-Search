{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IncidentLog",
  "description": "Operational provenance records for incident events.",
  "type": "object",
  "required": ["schema_version", "entries"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "incident_log_v1"
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["entry_id", "incident_kind", "status", "actor_id", "resource_id", "timestamp_utc"],
        "properties": {
          "entry_id": {"type": "string"},
          "incident_kind": {
            "type": "string",
            "enum": ["data_integrity_incident", "hardware_incident", "network_incident", "security_incident", "software_incident"]
          },
          "status": {
            "type": "string",
            "enum": ["closed", "escalated", "open", "under_investigation"]
          },
          "actor_id": {"type": "string"},
          "resource_id": {"type": "string"},
          "timestamp_utc": {"type": "string"},
          "notes": {"type": ["string", "null"]}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
