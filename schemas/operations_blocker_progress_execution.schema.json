{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/operations_blocker_progress_execution.schema.json",
  "title": "Operations Blocker Progress Execution Records",
  "type": "object",
  "required": [
    "schema_version",
    "disclaimer",
    "operations_blocker_progress_execution_records"
  ],
  "properties": {
    "schema_version": {
      "const": "operations_blocker_progress_execution_v1"
    },
    "disclaimer": {
      "type": "string",
      "minLength": 1
    },
    "operations_blocker_progress_execution_records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "execution_id",
          "next_action_id",
          "action_id",
          "category",
          "next_action_status",
          "execution_status",
          "priority_rank",
          "operator_id",
          "executed_utc",
          "execution_note",
          "residual_blocker_count",
          "live_data_authorized",
          "external_submission_authorized"
        ],
        "properties": {
          "execution_id": {
            "type": "string",
            "minLength": 1
          },
          "next_action_id": {
            "type": "string",
            "minLength": 1
          },
          "action_id": {
            "type": "string",
            "minLength": 1
          },
          "category": {
            "type": "string",
            "enum": [
              "alerts",
              "capacity",
              "curated_intake",
              "external_submission",
              "network_access",
              "pipeline_health",
              "quality_control",
              "review_deadlines",
              "route_coverage",
              "sqlite_logs",
              "submission_provenance",
              "validation_readiness"
            ]
          },
          "next_action_status": {
            "type": "string",
            "enum": [
              "blocked_pending_real_data",
              "local_note_ready",
              "no_action_required",
              "operator_action_required",
              "policy_review_required"
            ]
          },
          "execution_status": {
            "type": "string",
            "enum": [
              "awaiting_operator",
              "blocked_pending_real_data",
              "local_note_recorded",
              "no_execution_required",
              "policy_review_pending"
            ]
          },
          "priority_rank": {
            "type": "integer",
            "minimum": 1
          },
          "operator_id": {
            "type": "string",
            "minLength": 1
          },
          "executed_utc": {
            "type": "string",
            "format": "date-time"
          },
          "execution_note": {
            "type": "string",
            "minLength": 1
          },
          "residual_blocker_count": {
            "type": "integer",
            "minimum": 0
          },
          "live_data_authorized": {
            "type": "boolean"
          },
          "external_submission_authorized": {
            "type": "boolean"
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
