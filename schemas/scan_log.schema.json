{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "scan_log.schema.json",
  "title": "Scan Log",
  "description": "Operational provenance records for individual telescope scan events.",
  "type": "object",
  "required": ["schema_version", "disclaimer", "entries"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "scan_log_v1"
    },
    "disclaimer": {
      "type": "string"
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ScanEntry"
      }
    }
  },
  "$defs": {
    "ScanEntry": {
      "type": "object",
      "required": [
        "entry_id",
        "scan_kind",
        "status",
        "recorded_by",
        "scan_start",
        "track"
      ],
      "properties": {
        "entry_id": { "type": "string" },
        "scan_kind": {
          "type": "string",
          "enum": [
            "on_source",
            "off_source",
            "calibrator",
            "reference_position",
            "slew"
          ]
        },
        "status": {
          "type": "string",
          "enum": ["completed", "aborted", "flagged", "pending"]
        },
        "recorded_by": { "type": "string" },
        "scan_start": { "type": "string" },
        "track": { "type": "string" },
        "scan_duration_seconds": {
          "oneOf": [{ "type": "number" }, { "type": "null" }]
        },
        "target_name": {
          "oneOf": [{ "type": "string" }, { "type": "null" }]
        },
        "notes": {
          "oneOf": [{ "type": "string" }, { "type": "null" }]
        }
      },
      "additionalProperties": false
    }
  }
}
