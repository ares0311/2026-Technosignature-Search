{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CandidateLinkageLog",
  "description": "Operational records linking related candidates together.",
  "type": "object",
  "required": ["candidate_linkage_entries"],
  "properties": {
    "candidate_linkage_entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["linkage_id","candidate_id_a","candidate_id_b","linkage_kind","status","linked_by","linked_utc"],
        "properties": {
          "linkage_id": {"type": "string"},
          "candidate_id_a": {"type": "string"},
          "candidate_id_b": {"type": "string"},
          "linkage_kind": {"type": "string", "enum": ["same_source","temporal_followup","spatial_neighbor","frequency_related","cross_track"]},
          "status": {"type": "string", "enum": ["proposed","confirmed","rejected","under_review"]},
          "linked_by": {"type": "string"},
          "linked_utc": {"type": "string"},
          "separation_arcsec": {"type": ["number","null"]},
          "notes": {"type": "string"}
        }
      }
    }
  }
}
