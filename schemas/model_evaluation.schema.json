{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ModelEvaluation",
  "description": "Synthetic ML model evaluation results. Not detections or external validation.",
  "type": "object",
  "required": ["schema_version", "evaluations"],
  "properties": {
    "schema_version": { "type": "string" },
    "evaluations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "eval_id", "model_id", "track", "accuracy", "precision",
          "recall", "f1", "baseline_accuracy", "beats_baseline",
          "eval_utc", "notes"
        ],
        "properties": {
          "eval_id": { "type": "string" },
          "model_id": { "type": "string" },
          "track": { "type": "string", "enum": ["radio", "infrared", "anomaly", "multi"] },
          "accuracy": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
          "precision": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
          "recall": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
          "f1": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
          "baseline_accuracy": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
          "beats_baseline": { "type": "boolean" },
          "eval_utc": { "type": "string" },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
