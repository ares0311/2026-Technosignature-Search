{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PipelineErrorLog",
  "type": "object",
  "required": ["schema_version", "pipeline_error_entries"],
  "properties": {
    "schema_version": {"type": "string"},
    "pipeline_error_entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["error_id", "error_kind", "severity", "resolved", "reported_by", "reported_utc", "pipeline_stage"],
        "properties": {
          "error_id": {"type": "string"},
          "error_kind": {
            "type": "string",
            "enum": ["scoring_failure", "data_missing", "config_mismatch", "timeout", "validation_error"]
          },
          "severity": {
            "type": "string",
            "enum": ["warning", "error", "critical"]
          },
          "resolved": {"type": "boolean"},
          "reported_by": {"type": "string"},
          "reported_utc": {"type": "string"},
          "pipeline_stage": {"type": "string"},
          "resolved_utc": {"type": ["string", "null"]},
          "notes": {"type": "string"}
        }
      }
    }
  }
}
