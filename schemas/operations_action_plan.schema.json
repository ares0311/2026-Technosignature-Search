{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OperationsActionPlan",
  "description": "Prioritized local operator action plan derived from operations-readiness blockers. This artifact does not authorize live data access or external submission.",
  "type": "object",
  "required": [
    "schema_version",
    "disclaimer",
    "action_count",
    "critical_action_count",
    "real_data_blocking_action_count",
    "operator_review_action_count",
    "all_actions_clear",
    "by_category",
    "by_priority",
    "by_status",
    "actions"
  ],
  "properties": {
    "schema_version": {"const": "operations_action_plan_v1"},
    "disclaimer": {"type": "string"},
    "action_count": {"type": "integer", "minimum": 0},
    "critical_action_count": {"type": "integer", "minimum": 0},
    "real_data_blocking_action_count": {"type": "integer", "minimum": 0},
    "operator_review_action_count": {"type": "integer", "minimum": 0},
    "all_actions_clear": {"type": "boolean"},
    "by_category": {
      "type": "object",
      "additionalProperties": {"type": "integer", "minimum": 0}
    },
    "by_priority": {
      "type": "object",
      "additionalProperties": {"type": "integer", "minimum": 0}
    },
    "by_status": {
      "type": "object",
      "additionalProperties": {"type": "integer", "minimum": 0}
    },
    "next_action": {
      "type": ["object", "null"],
      "properties": {
        "action_id": {"type": "string"},
        "category": {"type": "string"},
        "priority": {"type": "string"},
        "status": {"type": "string"},
        "title": {"type": "string"},
        "required_action": {"type": "string"},
        "evidence_field": {"type": "string"},
        "blocker_count": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "action_id",
          "category",
          "priority",
          "status",
          "title",
          "required_action",
          "evidence_field",
          "blocker_count"
        ],
        "properties": {
          "action_id": {"type": "string"},
          "category": {
            "type": "string",
            "enum": [
              "quality_control",
              "capacity",
              "alerts",
              "review_deadlines",
              "pipeline_health",
              "validation_readiness",
              "curated_intake",
              "submission_provenance",
              "route_coverage",
              "sqlite_logs",
              "external_submission",
              "network_access"
            ]
          },
          "priority": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"]
          },
          "status": {
            "type": "string",
            "enum": ["open", "blocked_for_real_data", "operator_review_required"]
          },
          "title": {"type": "string"},
          "required_action": {"type": "string"},
          "evidence_field": {"type": "string"},
          "blocker_count": {"type": "integer", "minimum": 0}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
