{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DisasterRecoveryLog",
  "description": "Operational provenance records for disaster recovery events.",
  "type": "object",
  "required": ["schema_version", "entries"],
  "properties": {
    "schema_version": {"type": "string"},
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["entry_id", "recovery_kind", "status", "actor_id", "resource_id", "timestamp_utc"],
        "properties": {
          "entry_id": {"type": "string"},
          "recovery_kind": {"type": "string", "enum": ["backup_restore", "business_continuity_drill", "failover", "recovery_test", "redundancy_check"]},
          "status": {"type": "string", "enum": ["completed", "failed", "in_progress", "scheduled"]},
          "actor_id": {"type": "string"},
          "resource_id": {"type": "string"},
          "timestamp_utc": {"type": "string"},
          "notes": {"type": ["string", "null"]}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
