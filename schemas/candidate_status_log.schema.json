{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CandidateStatusLog",
  "description": "Operational provenance records for candidate status transitions.",
  "type": "object",
  "required": ["candidate_status_entries"],
  "properties": {
    "candidate_status_entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["entry_id","candidate_id","transition_kind","current_status","transitioned_by","transitioned_at","track"],
        "properties": {
          "entry_id": {"type": "string"},
          "candidate_id": {"type": "string"},
          "transition_kind": {"type": "string", "enum": ["initial","promotion","demotion","hold","archive"]},
          "current_status": {"type": "string", "enum": ["new","active","under_review","on_hold","archived"]},
          "previous_status": {"type": ["string","null"]},
          "transitioned_by": {"type": "string"},
          "transitioned_at": {"type": "string"},
          "track": {"type": "string"},
          "reason": {"type": ["string","null"]}
        }
      }
    }
  }
}
