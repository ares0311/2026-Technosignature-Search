{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "security_event_log.schema.json",
  "title": "Security Event Log",
  "description": "Operational provenance records for security events.",
  "type": "object",
  "required": ["schema_version", "disclaimer", "entries"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "security_event_log_v1"
    },
    "disclaimer": {
      "type": "string"
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/SecurityEventEntry"
      }
    }
  },
  "$defs": {
    "SecurityEventEntry": {
      "type": "object",
      "required": [
        "entry_id",
        "event_kind",
        "status",
        "severity",
        "actor_id",
        "resource_id",
        "timestamp_utc"
      ],
      "properties": {
        "entry_id": { "type": "string" },
        "event_kind": {
          "type": "string",
          "enum": [
            "credential_change",
            "intrusion_attempt",
            "physical_breach",
            "policy_violation",
            "unauthorized_access"
          ]
        },
        "status": {
          "type": "string",
          "enum": ["detected", "escalated", "investigated", "resolved"]
        },
        "severity": { "type": "string" },
        "actor_id": { "type": "string" },
        "resource_id": { "type": "string" },
        "timestamp_utc": { "type": "string" },
        "notes": {
          "oneOf": [{ "type": "string" }, { "type": "null" }]
        }
      },
      "additionalProperties": false
    }
  }
}
