{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "performance_monitoring_log.schema.json",
  "title": "Performance Monitoring Log",
  "type": "object",
  "required": ["schema_version", "disclaimer", "entries"],
  "properties": {
    "schema_version": {"type": "string", "const": "performance_monitoring_log_v1"},
    "disclaimer": {"type": "string"},
    "entries": {
      "type": "array",
      "items": {"$ref": "#/$defs/PerformanceMonitoringEntry"}
    }
  },
  "additionalProperties": false,
  "$defs": {
    "PerformanceMonitoringEntry": {
      "type": "object",
      "required": ["entry_id", "performance_kind", "status", "actor_id", "resource_id", "timestamp_utc"],
      "properties": {
        "entry_id": {"type": "string"},
        "performance_kind": {
          "type": "string",
          "enum": ["cpu_utilization", "disk_io", "memory_utilization", "network_throughput", "response_time"]
        },
        "status": {
          "type": "string",
          "enum": ["alert", "critical", "degraded", "normal"]
        },
        "actor_id": {"type": "string"},
        "resource_id": {"type": "string"},
        "timestamp_utc": {"type": "string"},
        "notes": {"oneOf": [{"type": "string"}, {"type": "null"}]}
      },
      "additionalProperties": false
    }
  }
}
