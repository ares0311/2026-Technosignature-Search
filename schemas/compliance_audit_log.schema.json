{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ComplianceAuditLog",
  "description": "Operational provenance records for compliance audit events.",
  "type": "object",
  "required": ["schema_version", "entries"],
  "properties": {
    "schema_version": {"type": "string"},
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["entry_id", "audit_kind", "status", "actor_id", "resource_id", "timestamp_utc"],
        "properties": {
          "entry_id": {"type": "string"},
          "audit_kind": {"type": "string", "enum": ["access_policy", "data_handling", "operational_policy", "retention_policy", "security_policy"]},
          "status": {"type": "string", "enum": ["failed", "passed", "under_review", "waived"]},
          "actor_id": {"type": "string"},
          "resource_id": {"type": "string"},
          "timestamp_utc": {"type": "string"},
          "notes": {"type": ["string", "null"]}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
