{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "risk_assessment_log.schema.json",
  "title": "Risk Assessment Log",
  "type": "object",
  "required": ["schema_version", "disclaimer", "entries"],
  "properties": {
    "schema_version": {"type": "string", "const": "risk_assessment_log_v1"},
    "disclaimer": {"type": "string"},
    "entries": {
      "type": "array",
      "items": {"$ref": "#/$defs/RiskAssessmentEntry"}
    }
  },
  "additionalProperties": false,
  "$defs": {
    "RiskAssessmentEntry": {
      "type": "object",
      "required": ["entry_id", "risk_kind", "status", "actor_id", "resource_id", "timestamp_utc"],
      "properties": {
        "entry_id": {"type": "string"},
        "risk_kind": {
          "type": "string",
          "enum": ["compliance_risk", "cyber_risk", "environmental_risk", "operational_risk", "physical_risk"]
        },
        "status": {
          "type": "string",
          "enum": ["accepted", "assessed", "identified", "mitigated"]
        },
        "actor_id": {"type": "string"},
        "resource_id": {"type": "string"},
        "timestamp_utc": {"type": "string"},
        "notes": {"oneOf": [{"type": "string"}, {"type": "null"}]}
      },
      "additionalProperties": false
    }
  }
}
