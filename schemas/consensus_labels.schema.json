{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/techno-search/consensus_labels.schema.json",
  "title": "Technosignature Search human-review consensus labels",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "description",
    "disclaimer",
    "allowed_consensus_labels",
    "items"
  ],
  "properties": {
    "schema_version": {
      "const": "human_review_consensus_labels_v1"
    },
    "description": {
      "type": "string"
    },
    "disclaimer": {
      "type": "string"
    },
    "allowed_consensus_labels": {
      "type": "array",
      "items": {
        "enum": [
          "follow_up_target",
          "insufficient_evidence",
          "known_object_annotation",
          "likely_false_positive",
          "no_consensus"
        ]
      },
      "minItems": 5,
      "uniqueItems": true
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "candidate_id",
          "track",
          "consensus_label",
          "reviewer_decisions"
        ],
        "properties": {
          "candidate_id": {
            "type": "string"
          },
          "track": {
            "enum": [
              "radio",
              "infrared",
              "anomaly"
            ]
          },
          "consensus_label": {
            "enum": [
              "follow_up_target",
              "insufficient_evidence",
              "known_object_annotation",
              "likely_false_positive",
              "no_consensus"
            ]
          },
          "reviewer_decisions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "reviewer_id",
                "triage_label",
                "created_at_utc",
                "rationale"
              ],
              "properties": {
                "reviewer_id": {
                  "type": "string"
                },
                "triage_label": {
                  "enum": [
                    "follow_up_target",
                    "insufficient_evidence",
                    "known_object_annotation",
                    "likely_false_positive",
                    "needs_human_review"
                  ]
                },
                "created_at_utc": {
                  "type": "string"
                },
                "rationale": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  }
}
