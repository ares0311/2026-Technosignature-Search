{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/techno-search/background_search_ledger.schema.json",
  "title": "Technosignature Search passive background search ledger",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "description",
    "disclaimer",
    "ledger_entries"
  ],
  "properties": {
    "schema_version": {
      "const": "background_search_ledger_v1"
    },
    "description": {
      "type": "string"
    },
    "disclaimer": {
      "type": "string"
    },
    "ledger_entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "run_id",
          "target_id",
          "track",
          "status",
          "query_parameters",
          "started_at_utc",
          "completed_at_utc",
          "config_version",
          "code_commit",
          "cache_key",
          "candidate_count",
          "recommended_pathways",
          "blocking_issues"
        ],
        "properties": {
          "run_id": {
            "type": "string"
          },
          "target_id": {
            "type": "string"
          },
          "track": {
            "enum": [
              "radio",
              "infrared",
              "anomaly"
            ]
          },
          "status": {
            "type": "string"
          },
          "query_parameters": {
            "type": "object"
          },
          "started_at_utc": {
            "type": "string"
          },
          "completed_at_utc": {
            "type": "string"
          },
          "config_version": {
            "type": "string"
          },
          "code_commit": {
            "type": "string"
          },
          "cache_key": {
            "type": "string"
          },
          "candidate_count": {
            "type": "integer",
            "minimum": 0
          },
          "execution_mode": {
            "type": "string"
          },
          "selected_priority_score": {
            "type": [
              "number",
              "null"
            ]
          },
          "target_selection_rationale": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "candidate_packet_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "negative_result_logged": {
            "type": "boolean"
          },
          "requires_human_review": {
            "type": "boolean"
          },
          "reviewed_workflow_status": {
            "enum": [
              "candidate_packet_ready",
              "local_scheduling_only",
              "needs_follow_up_required",
              "negative_search_recorded",
              "reviewed_no_follow_up",
              "review_blocked",
              "unreviewed"
            ]
          },
          "recommended_pathways": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "blocking_issues": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
