{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PipelineReplayLog",
  "description": "Append-only reproducibility records for pipeline re-runs. Replay does not modify committed candidate packets.",
  "type": "object",
  "required": ["pipeline_replay_entries"],
  "properties": {
    "pipeline_replay_entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "replay_id",
          "candidate_id",
          "original_config_id",
          "replay_config_id",
          "original_score",
          "replayed_score",
          "outcome",
          "score_delta",
          "replay_utc"
        ],
        "properties": {
          "replay_id": {"type": "string"},
          "candidate_id": {"type": "string"},
          "original_config_id": {"type": "string"},
          "replay_config_id": {"type": "string"},
          "original_score": {"type": "number", "minimum": 0, "maximum": 1},
          "replayed_score": {"type": "number", "minimum": 0, "maximum": 1},
          "outcome": {
            "type": "string",
            "enum": ["score_matched", "score_diverged", "config_mismatch", "replay_error"]
          },
          "score_delta": {"type": "number"},
          "replay_utc": {"type": "string"},
          "notes": {"type": "string"}
        }
      }
    }
  }
}
