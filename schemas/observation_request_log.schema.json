{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ObservationRequestLog",
  "type": "object",
  "required": ["schema_version", "observation_request_entries"],
  "properties": {
    "schema_version": {"type": "string"},
    "observation_request_entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["request_id", "candidate_id", "request_kind", "status", "requested_by", "requested_utc"],
        "properties": {
          "request_id": {"type": "string"},
          "candidate_id": {"type": "string"},
          "request_kind": {
            "type": "string",
            "enum": ["target_followup", "reobservation", "calibration_check", "verification", "archival_search"]
          },
          "status": {
            "type": "string",
            "enum": ["submitted", "acknowledged", "scheduled", "completed", "rejected", "withdrawn"]
          },
          "requested_by": {"type": "string"},
          "requested_utc": {"type": "string"},
          "target_utc": {"type": ["string", "null"]},
          "instrument": {"type": ["string", "null"]},
          "notes": {"type": "string"}
        }
      }
    }
  }
}
